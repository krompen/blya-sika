# ========== PAYMENTS ==========
async def pre_checkout_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.pre_checkout_query
    await query.answer(ok=True)

async def successful_payment_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    payload = update.message.successful_payment.invoice_payload
    
    if payload.startswith("diamonds_"):
        amount = int(payload.split("_")[1])
        add_diamonds(user_id, amount, "purchase", f"Purchased {amount} diamonds")
        await update.message.reply_text(f"✅ PAYMENT SUCCESSFUL!\n💰 {amount}💎 ADDED!", reply_markup=main_keyboard(user_id))

# ========== MAIN ==========
def main():
    app = Application.builder().token(TOKEN).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(PreCheckoutQueryHandler(pre_checkout_handler))
    app.add_handler(MessageHandler(filters.SUCCESSFUL_PAYMENT, successful_payment_handler))
    app.add_handler(MessageHandler(filters.PHOTO | filters.VIDEO | filters.TEXT & ~filters.COMMAND, handle_text))
    app.add_handler(CallbackQueryHandler(button_handler))
    
    print("🚀 CONTENT BOT STARTED!")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()