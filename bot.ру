async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    username = user.username or str(user.id)
    
    referrer_id = None
    if context.args and context.args[0].startswith("ref_"):
        try:
            referrer_id = int(context.args[0].split("_")[1])
            if referrer_id == user.id:
                referrer_id = None
        except:
            pass
    
    add_user(user.id, username, user.full_name, referrer_id)
    
    user_data = get_user(user.id)
    if user_data and user_data[6] == 1:
        await update.message.reply_text(f"🚫 YOU ARE BANNED!\nREASON: {user_data[7]}", reply_markup=back_keyboard())
        return
    
    await update.message.reply_text(
        f"✨ WELCOME! ✨\n\n"
        f"🎬 Your personal content bot!\n"
        f"📸 Watch videos and photos for diamonds\n"
        f"💎 Earn diamonds by completing tasks\n\n"
        f"⚠️ REQUIRED SUBSCRIPTION:\n"
        f"🔗 {REQUIRED_CHANNEL}\n\n"
        f"⬇️ AFTER SUBSCRIBING PRESS THE BUTTON:",
        reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton("✅ I SUBSCRIBED", callback_data="check_channel_sub")]
        ])
    )

async def check_channel_subscription(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    user_id = query.from_user.id
    
    # Для создателя всегда пропускаем проверку
    if user_id == CREATOR_ID:
        await query.edit_message_text(
            "✅ WELCOME!\n\n⬇️ CHOOSE ACTION:",
            reply_markup=main_keyboard(user_id)
        )
        check_daily_bonus(user_id)
        return
    
    # Проверяем подписку (требует чтобы бот был админом в канале)
    try:
        chat_member = await context.bot.get_chat_member(chat_id=REQUIRED_CHANNEL, user_id=user_id)
        if chat_member.status in ["member", "administrator", "creator"]:
            await query.edit_message_text(
                "✅ SUBSCRIPTION CONFIRMED!\n\n⬇️ CHOOSE ACTION:",
                reply_markup=main_keyboard(user_id)
            )
            check_daily_bonus(user_id)
        else:
            await query.edit_message_text(
                f"❌ YOU ARE NOT SUBSCRIBED TO {REQUIRED_CHANNEL}!\n\n"
                f"🔗 SUBSCRIBE AND PRESS THE BUTTON AGAIN.",
                reply_markup=InlineKeyboardMarkup([
                    [InlineKeyboardButton("✅ I SUBSCRIBED", callback_data="check_channel_sub")]
                ])
            )
    except Exception as e:
        # Если бот не админ в канале, пропускаем проверку
        await query.edit_message_text(
            "✅ WELCOME!\n\n⬇️ CHOOSE ACTION:",
            reply_markup=main_keyboard(user_id)
        )
        check_daily_bonus(user_id)

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    data = query.data
    await query.answer()
    user_id = query.from_user.id
    username = query.from_user.username or str(user_id)
    
    user_data = get_user(user_id)
    if user_data and user_data[6] == 1:
        await query.edit_message_text(f"🚫 YOU ARE BANNED!\nREASON: {user_data[7]}", reply_markup=back_keyboard())
        return
    
    user_data = get_user(user_id)
    diamonds = user_data[4] if user_data else 0
    
    if data == "noop":
        return
    
    elif data == "back":
        context.user_data.clear()
        await query.edit_message_text("⬇️ CHOOSE ACTION:", reply_markup=main_keyboard(user_id))
    
    elif data == "check_channel_sub":
        await check_channel_subscription(update, context)
        return
    
