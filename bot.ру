def get_random_content(content_type):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT COUNT(*) FROM content WHERE type = ?', (content_type,))
    count = c.fetchone()[0]
    if count == 0:
        conn.close()
        return None
    random_id = random.randint(1, count)
    c.execute('SELECT id, file_id, price FROM content WHERE type = ? LIMIT 1 OFFSET ?', (content_type, random_id-1))
    result = c.fetchone()
    conn.close()
    return result

