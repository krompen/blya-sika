                [InlineKeyboardButton("💎 500 DIAMONDS - 40⭐", callback_data="buy_500")],
                [InlineKeyboardButton("💎 1000 DIAMONDS - 70⭐", callback_data="buy_1000")],
                [InlineKeyboardButton("🔙 BACK", callback_data="back")]
