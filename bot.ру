# ========== ОТЗЫВЫ ==========
async def start_review(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    now = datetime.now()
    
    if user_id in last_review_time:
        last = last_review_time[user_id]
        if now - last < timedelta(minutes=ANTISPAM_MINUTES):
            wait = ANTISPAM_MINUTES - (now - last).seconds // 60
            await update.message.reply_text(f"⏳ Подождите {wait} минут перед следующим отзывом.", reply_markup=get_keyboard(user_id))
            return ConversationHandler.END
    
    keyboard = get_keyboard(user_id)
    await update.message.reply_text("⭐ Поставьте оценку (1-5 звёзд):", reply_markup=rating_buttons())
    return RATING

async def get_rating(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    rating = int(query.data.split("_")[1])
    context.user_data["rating"] = rating
    
    await query.edit_message_text(
        f"⭐ Оценка: {'🌟' * rating} ({rating}/5)\n\n✏️ Напишите текст отзыва.\nОбязательно упомяните {MY_USERNAME}:\n(минимум {MIN_REVIEW_LENGTH} символов)",
        reply_markup=cancel_button()
    )
    return REVIEW_TEXT

async def get_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text.strip()
    
    if len(text) < MIN_REVIEW_LENGTH:
        await update.message.reply_text(f"❌ Слишком коротко. Напишите минимум {MIN_REVIEW_LENGTH} символов:", reply_markup=cancel_button())
        return REVIEW_TEXT
    
    if MY_USERNAME not in text:
        await update.message.reply_text(f"❌ Пожалуйста, упомяните {MY_USERNAME} в отзыве:\n(например: «{MY_USERNAME} сделал отличную аватарку»)", reply_markup=cancel_button())
        return REVIEW_TEXT
    
    context.user_data["review_text"] = text
    rating = context.user_data["rating"]
    
    preview = f"📝 ПРЕДПРОСМОТР\n\n⭐ {'🌟' * rating} ({rating}/5)\n📝 {text}\n\n✅ Всё верно?"
    await update.message.reply_text(preview, reply_markup=confirm_buttons())
    return CONFIRM

async def confirm_review(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    if query.data == "confirm_no":
        await query.edit_message_text("❌ Отзыв отменён.")
        await query.message.reply_text("Главное меню:", reply_markup=get_keyboard(query.from_user.id))
        context.user_data.clear()
        return ConversationHandler.END
    
    # Сохраняем отзыв
    user = query.from_user
    rating = context.user_data["rating"]
    text = context.user_data["review_text"]
    username = f"@{user.username}" if user.username else None
    
    global next_review_id
    new_review = {
        "id": next_review_id,
        "user_id": user.id,
        "username": username,
        "rating": rating,
        "text": text,
        "date": datetime.now().isoformat(),
        "deleted": False
    }
    reviews.append(new_review)
    save_reviews(reviews)
    next_review_id += 1
    
    last_review_time[user.id] = datetime.now()
    save_last_time(last_review_time)
    
    # Отправляем в канал
    try:
        await context.bot.send_message(
            chat_id=CHANNEL_REVIEWS,
            text=f"⭐ НОВЫЙ ОТЗЫВ\n\nОценка: {'🌟' * rating} ({rating}/5)\nОт: {username or 'Пользователь'}\n\n📝 {text}",
            parse_mode=None
        )
    except Exception as e:
        print(f"Ошибка отправки в канал: {e}")
    
    await query.edit_message_text("✅ Спасибо! Ваш отзыв опубликован.")
    await query.message.reply_text("Главное меню:", reply_markup=get_keyboard(user.id))
    context.user_data.clear()
    return ConversationHandler.END

async def cancel_review(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.callback_query:
        await update.callback_query.answer()
        await update.callback_query.edit_message_text("❌ Отменено.")
        await update.callback_query.message.reply_text("Главное меню:", reply_markup=get_keyboard(update.callback_query.from_user.id))
    else:
        await update.message.reply_text("❌ Отменено.", reply_markup=get_keyboard(update.effective_user.id))
    context.user_data.clear()
    return ConversationHandler.END

