async def delete_my_review(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data.clear()
    user_id = update.effective_user.id
    user_reviews = [r for r in reviews if r["user_id"] == user_id and not r.get("deleted", False)]
    if not user_reviews:
        await update.message.reply_text("❌ У вас нет отзывов для удаления.", reply_markup=get_keyboard(user_id))
        return
    last = max(user_reviews, key=lambda x: x["id"])
    last["deleted"] = True
    save_reviews(reviews)
    await update.message.reply_text("✅ Ваш отзыв удалён.", reply_markup=get_keyboard(user_id))

