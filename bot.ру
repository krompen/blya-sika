# ========== ЗАПУСК ==========
async def post_init(app: Application):
    await app.bot.set_my_commands([
        BotCommand("start", "Главное меню"),
        BotCommand("profile", "Мой профиль"),
        BotCommand("delete_my_review", "Удалить мой отзыв"),
        BotCommand("cancel", "Отменить действие"),
    ])

def main():
    app = Application.builder().token(TOKEN).post_init(post_init).build()
    
    # Команды
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("profile", profile))
    app.add_handler(CommandHandler("delete_my_review", delete_my_review))
    app.add_handler(CommandHandler("cancel", cancel_all))
    app.add_handler(CommandHandler("cancel_broadcast", cancel_broadcast))
    
    # ConversationHandler для отзывов
    conv = ConversationHandler(
        entry_points=[MessageHandler(filters.Regex("^⭐ Оставить отзыв$"), start_review)],
        states={
            RATING: [CallbackQueryHandler(get_rating, pattern="^rate_")],
            REVIEW_TEXT: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_text)],
            CONFIRM: [CallbackQueryHandler(confirm_review, pattern="^confirm_")]
        },
        fallbacks=[CallbackQueryHandler(cancel_review, pattern="^cancel$"), CommandHandler("cancel", cancel_review)]
    )
    app.add_handler(conv)
    
    # Админ колбэки
    app.add_handler(CallbackQueryHandler(admin_callback, pattern="^(admin_|del_)"))
    
    # Рассылка
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, broadcast_message))
    
    # Кнопки меню
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_menu))
    
    print("✅ Бот запущен!")
    app.run_polling()

if __name__ == "__main__":
    main()