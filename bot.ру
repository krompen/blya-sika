    c.execute('INSERT OR IGNORE INTO bot_settings (key, value) VALUES ("subscribe_bonus", "5")')
    c.execute('INSERT OR IGNORE INTO bot_settings (key, value) VALUES ("tiktok_bonus", "15")')
    c.execute('INSERT OR IGNORE INTO bot_settings (key, value) VALUES ("admin_status", "online")')
    
    conn.commit()
    conn.close()

