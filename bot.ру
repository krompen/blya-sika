    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    expires = (datetime.datetime.now() + datetime.timedelta(days=expires_days)).strftime("%Y-%m-%d %H:%M:%S")
    try:
        c.execute('INSERT INTO promocodes (code, diamonds, created_at, expires_at) VALUES (?, ?, ?, ?)', (code.upper(), diamonds, now, expires))
        conn.commit()
        conn.close()
        return True
    except:
