# --- БАЗА ДАННЫХ ---
conn = sqlite3.connect('morph_final.db', check_same_thread=False)
c = conn.cursor()
c.execute('''CREATE TABLE IF NOT EXISTS users
             (user_id INTEGER PRIMARY KEY, 
              searches_left INTEGER DEFAULT 5, 
              is_premium INTEGER DEFAULT 0,
              premium_until TEXT DEFAULT 'None', 
              refs INTEGER DEFAULT 0,
              total_found INTEGER DEFAULT 0)''')
conn.commit()

# --- СЛОВАРЬ КРАСИВЫХ ПРЕФИКСОВ ---
RARITY = ["Обычный", "Редкий", "Элитный", "Мифический"]

# --- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ---
def get_user(uid):
    c.execute("SELECT searches_left, is_premium, premium_until, refs, total_found FROM users WHERE user_id=?", (uid,))
    res = c.fetchone()
    if not res:
        c.execute("INSERT INTO users (user_id) VALUES (?)", (uid,))
        conn.commit()
        return (5, 0, 'None', 0, 0)
    return res

def check_prem(uid):
    data = get_user(uid)
    if data[1] == 1:
        if data[2] != 'None':
            try:
                until = datetime.strptime(data[2], '%Y-%m-%d %H:%M:%S')
                return until > datetime.now()
            except: return False
    return False

def is_free(tag):
    try:
        time.sleep(0.35) # Защита от флуда
        bot.get_chat(f"@{tag}")
        return False
    except: return True

