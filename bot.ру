            f"🤍 Осталось запросов: {remaining}\n"
            f"💎 Статус: {premium_name}",
            reply_markup=InlineKeyboardMarkup(keyboard)
        )
    else:
        keyboard = [[InlineKeyboardButton("🔍 Новый поиск", callback_data="find")], [InlineKeyboardButton("🔙 Главное меню", callback_data="back")]]
