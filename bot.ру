# ========== БАЗА ДАННЫХ ==========
def init_db():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        premium INTEGER DEFAULT 0,
        requests_today INTEGER DEFAULT 5,
        last_reset TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS free_tags (
        tag TEXT PRIMARY KEY,
        found_date TEXT
    )''')
    conn.commit()
    conn.close()

init_db()

# ========== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ==========
def get_user(user_id, username=""):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT user_id, username, premium, requests_today, last_reset FROM users WHERE user_id = ?', (user_id,))
    user = c.fetchone()
    conn.close()
    if not user:
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        today = datetime.datetime.now().strftime("%Y-%m-%d")
        c.execute('INSERT INTO users (user_id, username, premium, requests_today, last_reset) VALUES (?, ?, 0, 5, ?)', (user_id, username, today))
        conn.commit()
        conn.close()
        return get_user(user_id, username)
    
    today = datetime.datetime.now().strftime("%Y-%m-%d")
    if user[4] != today:
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        c.execute('UPDATE users SET requests_today = 5, last_reset = ? WHERE user_id = ?', (today, user_id))
        conn.commit()
        conn.close()
        return (user[0], user[1], user[2], 5, today)
    return user

def use_request(user_id):
    user = get_user(user_id)
    if user[2] == 1:
        return True
    if user[3] <= 0:
        return False
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('UPDATE users SET requests_today = requests_today - 1 WHERE user_id = ?', (user_id,))
    conn.commit()
    conn.close()
    return True

def save_free_tag(tag):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT OR IGNORE INTO free_tags (tag, found_date) VALUES (?, ?)', (tag, now))
    conn.commit()
    conn.close()

def get_free_tag():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT tag FROM free_tags ORDER BY RANDOM() LIMIT 1')
    row = c.fetchone()
    conn.close()
    return row[0] if row else None

def remove_free_tag(tag):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('DELETE FROM free_tags WHERE tag = ?', (tag,))
    conn.commit()
    conn.close()

# ========== ПРОВЕРКА ТЕГА ==========
async def is_tag_free(tag):
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(f"https://t.me/{tag}", timeout=10) as resp:
                html = await resp.text()
                if "If you have Telegram, you can contact" in html:
                    return False
                return True
    except:
        return True

