# ========== ФУНКЦИИ ==========
def get_profile_text():
    active = [r for r in reviews if not r.get("deleted", False)]
    if not active:
        return "📋 МОЙ ПРОФИЛЬ\n\n⭐ Оценок пока нет\n📊 Отзывов: 0\n\nБудь первым, кто оставит отзыв!"
    
    total = len(active)
    positive = sum(1 for r in active if r["rating"] >= 4)
    avg = sum(r["rating"] for r in active) / total
    
    last = active[-3:][::-1]
    last_text = ""
    for r in last:
        stars = "🌟" * r["rating"]
        name = r.get("username", "Пользователь")
        last_text += f"\n{stars} {name}\n{r['text'][:60]}...\n"
    
    return f"📋 МОЙ ПРОФИЛЬ\n\n⭐ Рейтинг: {avg:.1f}/5.0\n📊 Отзывов: {total} (👍 {positive} / 👎 {total-positive})\n\n📝 Последние отзывы:{last_text}"

