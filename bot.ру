        c.execute('INSERT OR IGNORE INTO users (user_id, username, premium_level, daily_requests, last_reset, total_requests, ref_by, daily_bonus_last) VALUES (?, ?, 0, 5, ?, 0, ?, ?)',
                  (user_id, username, today, ref_by, today))
        conn.commit()
