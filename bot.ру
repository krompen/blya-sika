        [InlineKeyboardButton("📊 Статистика", callback_data="admin_stats")],
        [InlineKeyboardButton("📢 Рассылка", callback_data="admin_broadcast")],
        [InlineKeyboardButton("🗑 Управление отзывами", callback_data="admin_manage")],
        [InlineKeyboardButton("📤 Экспорт", callback_data="admin_export")]
    ])
    await update.message.reply_text("🔐 АДМИН ПАНЕЛЬ\n\nВыберите действие:", reply_markup=keyboard)

async def admin_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    user_id = query.from_user.id
    
    if user_id != ADMIN_ID:
        await query.edit_message_text("⛔ Нет доступа.")
        return
    
    if query.data == "admin_stats":
        active = [r for r in reviews if not r.get("deleted", False)]
        if not active:
            text = "📊 Нет отзывов"
        else:
            avg = sum(r["rating"] for r in active) / len(active)
            pos = sum(1 for r in active if r["rating"] >= 4)
            text = f"📊 СТАТИСТИКА\n\nВсего: {len(active)}\nРейтинг: {avg:.2f}/5\nПоложительных: {pos}\nОтрицательных: {len(active)-pos}\nУникальных: {len(set(r['user_id'] for r in active))}"
        await query.edit_message_text(text)
        
    elif query.data == "admin_export":
        active = [r for r in reviews if not r.get("deleted", False)]
        with open("export.json", "w", encoding="utf-8") as f:
            json.dump(active, f, ensure_ascii=False, indent=2)
        await query.message.reply_document(document=open("export.json", "rb"), filename="reviews_export.json")
        os.remove("export.json")
        await query.edit_message_text("📤 Экспорт отправлен.")
        
    elif query.data == "admin_broadcast":
        context.user_data["broadcast_mode"] = True
        await query.edit_message_text("📢 Введите текст рассылки (отмена: /cancel_broadcast):")
        
    elif query.data == "admin_manage":
        active = [r for r in reviews if not r.get("deleted", False)]
        if not active:
            await query.edit_message_text("Нет отзывов.")
            return
        # Показываем последние 5
        for r in active[-5:][::-1]:
            btn = InlineKeyboardMarkup([[InlineKeyboardButton("🗑 Удалить", callback_data=f"del_{r['id']}")]])
            await query.message.reply_text(f"ID: {r['id']}\n⭐ {'🌟'*r['rating']}\n{r['username']}\n{r['text'][:100]}", reply_markup=btn)
        await query.delete_message()
        
    elif query.data.startswith("del_"):
        rid = int(query.data.split("_")[1])
        for r in reviews:
            if r["id"] == rid and not r.get("deleted", False):
                r["deleted"] = True
                save_reviews(reviews)
                await query.edit_message_text(f"✅ Отзыв {rid} удалён.")
                break

async def broadcast_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if context.user_data.get("broadcast_mode") and update.effective_user.id == ADMIN_ID:
        text = update.message.text
        users = set(r["user_id"] for r in reviews if not r.get("deleted", False))
        success = 0
        await update.message.reply_text(f"📢 Начинаю рассылку {len(users)} пользователям...")
        for uid in users:
            try:
                await context.bot.send_message(uid, f"📢 РАССЫЛКА\n\n{text}")
                success += 1
                await asyncio.sleep(0.05)
            except:
                pass
        await update.message.reply_text(f"✅ Отправлено: {success}\n❌ Ошибок: {len(users)-success}")
        context.user_data.pop("broadcast_mode", None)

async def cancel_broadcast(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if context.user_data.get("broadcast_mode"):
        context.user_data.pop("broadcast_mode")
        await update.message.reply_text("❌ Рассылка отменена.", reply_markup=get_keyboard(update.effective_user.id))

