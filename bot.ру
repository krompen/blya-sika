        BotCommand("start", "Запуск бота"),
        BotCommand("info", "Информация"),
        BotCommand("balance", "Мой баланс"),
    ]
    await app.bot.set_my_commands(commands)

def main():
    app = Application.builder().token(BOT_TOKEN).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("info", lambda u, c: u.message.reply_text(f"ℹ️ TEG SEARCH GIFTS\n\nАдмин: {ADMIN_USERNAME}")))
    app.add_handler(CommandHandler("balance", lambda u, c: u.message.reply_text(f"💰 Ваш баланс: {get_balance(u.effective_user.id)}⭐")))
    
    app.add_handler(CommandHandler("add_template", add_template_cmd))
