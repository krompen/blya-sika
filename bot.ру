async def handle_ticket(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if context.user_data.get("awaiting_ticket"):
        user_id = update.effective_user.id
        username = update.effective_user.username or "без юзернейма"
        question = update.message.text
        await update.message.reply_text(f"✅ Сообщение отправлено! Админ ответит в ближайшее время.")
        await context.bot.send_message(
            chat_id=ADMIN_ID,
            text=f"🆕 **Новое сообщение в поддержку**\n👤 @{username} (ID: {user_id})\n📝 {question}"
        )
        context.user_data["awaiting_ticket"] = False

async def back(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    await start(update, context)

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    data = query.data
    await query.answer()
    
    if data == "find":
        await find_free_tag(query, context, from_callback=True)
    elif data == "profile":
        await profile(update, context)
    elif data == "premium":
        await premium_info(update, context)
    elif data == "support":
        await support_menu(update, context)
    elif data == "back":
        await start(update, context)

# ========== АДМИН-КОМАНДЫ ==========
async def give_premium(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        await update.message.reply_text("⛔ Нет прав.")
        return
    if len(context.args) < 1:
        await update.message.reply_text("❌ /givepremium <user_id>")
        return
    try:
        user_id = int(context.args[0])
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        c.execute('UPDATE users SET premium = 1 WHERE user_id = ?', (user_id,))
        conn.commit()
        conn.close()
        await update.message.reply_text(f"✅ Пользователь {user_id} получил премиум.")
        await context.bot.send_message(chat_id=user_id, text="🎉 Вам выдан премиум! Теперь безлимитный поиск.")
    except:
        await update.message.reply_text("❌ Неверный ID.")

# ========== ЗАПУСК ==========
def main():
    app = Application.builder().token(TOKEN).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("givepremium", give_premium))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_ticket))
    app.add_handler(CallbackQueryHandler(button_handler))
    
    loop = asyncio.get_event_loop()
    loop.create_task(collect_free_tags())
    
    print("✅ Бот запущен")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()