def add_user(user_id, username, full_name, referrer_id=None):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    
    c.execute('INSERT OR IGNORE INTO users (user_id, username, full_name, registered_at) VALUES (?, ?, ?, ?)',
              (user_id, username, full_name, now))
    
    # Если есть реферер и пользователь новый
    if referrer_id and referrer_id != user_id:
        c.execute('SELECT user_id FROM users WHERE user_id = ?', (referrer_id,))
        if c.fetchone():
            c.execute('INSERT INTO referrals (referrer_id, referred_id, created_at) VALUES (?, ?, ?)',
                      (referrer_id, user_id, now))
            # Начисляем бонус рефереру
            ref_bonus = get_setting("ref_bonus", REF_BONUS)
            add_diamonds(referrer_id, ref_bonus, "referral", f"Бонус за приглашение @{username}")
    
    # Если админ — даём уровень 3
    if user_id == ADMIN_ID:
        c.execute('UPDATE users SET level = 3 WHERE user_id = ?', (user_id,))
    
    conn.commit()
    conn.close()

