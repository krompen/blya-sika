async def add_template_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    if len(context.args) < 4:
        await update.message.reply_text("/add_template ID Название Цена Текст")
        return
    
    tid = context.args[0]
    name = context.args[1]
    price = int(context.args[2])
    text = " ".join(context.args[3:])
    
    with get_db_connection() as conn:
        conn.execute('''INSERT OR REPLACE INTO templates (id, name, price, text, active) 
                       VALUES (?, ?, ?, ?, 1)''', (tid, name, price, text))
        conn.commit()
    
    await update.message.reply_text(f"✅ Шаблон {name} добавлен!")

async def del_template_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    if not context.args:
        await update.message.reply_text("/del_template ID")
        return
    
    tid = context.args[0]
    with get_db_connection() as conn:
        conn.execute('UPDATE templates SET active = 0 WHERE id = ?', (tid,))
        conn.commit()
    
    await update.message.reply_text(f"✅ Шаблон {tid} отключён")

