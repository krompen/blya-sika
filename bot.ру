# Простые английские слова, которые можно изменять
WORDS = ["sky", "sun", "moon", "star", "cat", "dog", "fox", "bee", "ant", "fly", "owl", "rat", "bat", "bear", "wolf", "lion", "tiger", "deer", "frog", "fish", "bird", "fire", "ice", "air", "earth", "wind", "rain", "snow", "cloud", "tree", "flower", "grass", "stone", "rock", "hill", "lake", "river", "sea", "ocean", "wave", "sand", "gold", "silver", "iron", "steel", "wood", "apple", "brain", "dragon", "eagle", "flame", "glory", "heart", "light", "magic", "night", "power", "queen", "tiger", "unity", "vivid", "wings", "young", "zebra", "angel", "beast", "chaos", "death", "fairy", "ghost", "horse", "joker", "king", "lion", "moon", "ninja", "omega", "phantom", "raven", "saber", "titan", "ultra", "valor", "witch", "youth", "zeus", "blaze", "crown", "demon", "elite", "frost", "giant", "hawk", "icon", "jade", "knight", "lynx", "myth", "nova", "opal", "pulse", "quake", "reign", "storm", "thief", "venom", "wolf", "zero", "alive", "brave", "crazy", "dream", "great", "happy", "ideal", "karma", "lucky", "noble", "proud", "royal", "smart", "urban", "witty", "zesty"]

def generate_tag():
    base = random.choice(WORDS)
    # Иногда добавляем цифры или меняем буквы
    if random.random() > 0.7:
        return base + str(random.randint(10, 99))
    if random.random() > 0.8:
        return base[::-1]  # переворот
    return base

async def find_free_tag(update: Update, context: ContextTypes.DEFAULT_TYPE, from_callback=False):
    user_id = update.effective_user.id if hasattr(update, 'effective_user') else update.from_user.id
    user = get_user(user_id, update.effective_user.username if hasattr(update, 'effective_user') else update.from_user.username)
    
    if not use_request(user_id):
        await update.message.reply_text("❌ Лимит запросов на сегодня исчерпан. Завтра обнулится или купи премиум.")
        return
    
    if from_callback:
        msg = await update.edit_message_text("🔍 Ищу свободный тег...")
    else:
        msg = await update.message.reply_text("🔍 Ищу свободный тег...")
    
    # Сначала пробуем из базы
    cached = get_free_tag()
    if cached and await is_tag_free(cached):
        remove_free_tag(cached)
        await msg.edit_text(f"✅ **Найден свободный тег!**\n\n📝 @{cached}\n\n🤍 Осталось запросов: {user[3] - 1 if user[2] == 0 else '∞'}")
        return
    
    # Ищем новый
    found = False
    attempts = 0
    tag = ""
    while not found and attempts < 100:
        tag = generate_tag()
        found = await is_tag_free(tag)
        attempts += 1
        if found:
            save_free_tag(tag)
            break
    
    if found:
        await msg.edit_text(f"✅ **Найден свободный тег!**\n\n📝 @{tag}\n\n🤍 Осталось запросов: {user[3] - 1 if user[2] == 0 else '∞'}")
    else:
        await msg.edit_text("❌ Не удалось найти свободный тег. Попробуй позже.")

# ========== АВТОСБОР ТЕГОВ ==========
async def collect_free_tags():
    while True:
        for _ in range(3):
            tag = generate_tag()
            if await is_tag_free(tag):
                save_free_tag(tag)
        await asyncio.sleep(60)

