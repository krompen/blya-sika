# ========== ОБРАБОТКА ТЕКСТА ==========
async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    text = update.message.text
    username = update.effective_user.username or str(user_id)
    user_data = get_user(user_id)
    
    if user_data and user_data[6] == 1:
        await update.message.reply_text(f"🚫 ВЫ ЗАБАНЕНЫ!\nПРИЧИНА: {user_data[7]}", reply_markup=back_keyboard())
        return
    
    # ========== РАССЫЛКА ==========
    if context.user_data.get("awaiting_broadcast") and is_admin(user_id):
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        users = c.execute('SELECT user_id FROM users WHERE is_banned = 0').fetchall()
        conn.close()
        
        if not users:
            await update.message.reply_text("❌ НЕТ ПОЛЬЗОВАТЕЛЕЙ ДЛЯ РАССЫЛКИ!\n\n"
                                           "❗ КАК ДОБАВИТЬ ПОЛЬЗОВАТЕЛЕЙ:\n"
                                           "1. Зайди с другого аккаунта\n"
                                           "2. Напиши боту `/start`\n"
                                           "3. Пользователь добавится в БД", 
                                           reply_markup=back_keyboard())
            context.user_data["awaiting_broadcast"] = False
            return
        
        broadcast_text = f"╔════════════════════════════════════════╗\n"
        broadcast_text += f"║  📢 **СООБЩЕНИЕ ОТ АДМИНИСТРАЦИИ**     ║\n"
        broadcast_text += f"╠════════════════════════════════════════╣\n"
        broadcast_text += f"║                                        ║\n"
        broadcast_text += f"║  {text}                                ║\n"
        broadcast_text += f"║                                        ║\n"
        broadcast_text += f"║  ═══════════════════════════════════   ║\n"
        broadcast_text += f"║                                        ║\n"
        broadcast_text += f"║  🔗 **НАШ КАНАЛ:** {REQUIRED_CHANNEL}   ║\n"
        broadcast_text += f"║  📌 **НА СЛУЧАЙ БЛОКИРОВКИ БОТА:**      ║\n"
        broadcast_text += f"║  🔗 {REQUIRED_CHANNEL}                 ║\n"
        broadcast_text += f"║                                        ║\n"
        broadcast_text += f"╚════════════════════════════════════════╝"
        
        sent = 0
        failed = 0
        for u in users:
            try:
                await context.bot.send_message(chat_id=u[0], text=broadcast_text, parse_mode="Markdown")
                sent += 1
            except Exception as e:
                failed += 1
                print(f"Ошибка отправки {u[0]}: {e}")
        
        await update.message.reply_text(
            f"✅ РАССЫЛКА ЗАВЕРШЕНА!\n\n"
            f"📨 ОТПРАВЛЕНО: {sent}\n"
            f"❌ НЕ ДОСТАВЛЕНО: {failed}",
            reply_markup=main_keyboard(user_id)
        )
        context.user_data["awaiting_broadcast"] = False
        return
    
    # ========== ПРОМОКОД ==========
    if context.user_data.get("awaiting_promocode"):
        success, msg = use_promocode(user_id, text)
        if success:
            await update.message.reply_text(f"✅ {msg}", reply_markup=main_keyboard(user_id))
        else:
            await update.message.reply_text(f"❌ {msg}", reply_markup=back_keyboard())
        context.user_data["awaiting_promocode"] = False
        return
    
    # ========== ДОБАВЛЕНИЕ КОНТЕНТА ==========
    if context.user_data.get("awaiting_content") and is_admin(user_id):
        if update.message.photo:
            file_id = update.message.photo[-1].file_id
            file_type = "photo"
            price = get_setting("photo_price", 1)
            add_content(file_type, file_id, price)
            await update.message.reply_text(f"✅ ФОТО ДОБАВЛЕНО!\n💰 ЦЕНА: {price}💎\n\n📸 ОТПРАВЛЯЙ СЛЕДУЮЩЕЕ ИЛИ НАЖМИ «ГОТОВО»")
        elif update.message.video:
            file_id = update.message.video.file_id
            file_type = "video"
            price = get_setting("video_price", 2)
            add_content(file_type, file_id, price)
            await update.message.reply_text(f"✅ ВИДЕО ДОБАВЛЕНО!\n💰 ЦЕНА: {price}💎\n\n🎬 ОТПРАВЛЯЙ СЛЕДУЮЩЕЕ ИЛИ НАЖМИ «ГОТОВО»")
        else:
