        await query.edit_message_text("📭 Нет логов.", reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Назад", callback_data="admin")]]))
        return
    text = "📜 **Последние логи:**\n\n" + "\n".join([f"🆔 {l[0]} | {l[1]} | {l[2]}" for l in logs])
    await query.edit_message_text(text[:4000], reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Назад", callback_data="admin")]]))

async def admin_tickets(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    if query.from_user.id != ADMIN_ID:
        await query.answer("⛔ Нет доступа.", show_alert=True)
        return
    await query.answer()
    conn = sqlite3.connect(DB_NAME, timeout=10)
    tickets = conn.execute('SELECT id, user_id, username, question, created_at FROM tickets WHERE status = "open" ORDER BY id DESC').fetchall()
    conn.close()
    if not tickets:
        await query.edit_message_text("📭 Нет открытых тикетов.", reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Назад", callback_data="admin")]]))
        return
    text = "🆘 **Открытые тикеты:**\n\n" + "\n".join([f"#{t[0]} | @{t[2]} (ID: {t[1]})\n📝 {t[3][:50]}\n💡 /answer {t[0]} [текст]\n" for t in tickets])
    await query.edit_message_text(text[:4000], reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Назад", callback_data="admin")]]))

async def answer_ticket(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        await update.message.reply_text("⛔ Нет прав.")
        return
    if len(context.args) < 2:
        await update.message.reply_text("❌ /answer <ticket_id> <текст>")
        return
    try:
        ticket_id, answer = int(context.args[0]), " ".join(context.args[1:])
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        c.execute('SELECT user_id FROM tickets WHERE id = ?', (ticket_id,))
        row = c.fetchone()
        if not row:
            await update.message.reply_text("❌ Тикет не найден.")
            return
        c.execute('UPDATE tickets SET status = "closed", admin_answer = ?, answered_at = ? WHERE id = ?', (answer, datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S"), ticket_id))
        conn.commit()
        conn.close()
        await update.message.reply_text(f"✅ Ответ на тикет #{ticket_id} отправлен.")
        await context.bot.send_message(chat_id=row[0], text=f"📬 **Ответ на обращение #{ticket_id}**\n\n✅ {answer}")
    except:
        await update.message.reply_text("❌ Ошибка.")

async def admin_broadcast(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        await update.message.reply_text("⛔ Нет прав.")
        return
    if len(context.args) < 1:
        await update.message.reply_text("❌ /broadcast <текст>")
        return
    text = " ".join(context.args)
    conn = sqlite3.connect(DB_NAME, timeout=10)
    users = conn.execute('SELECT user_id FROM users').fetchall()
    conn.close()
    sent = 0
    for user in users:
        try:
            await context.bot.send_message(chat_id=user[0], text=f"📢 **РАССЫЛКА**\n\n{text}")
            sent += 1
        except:
            pass
    await update.message.reply_text(f"✅ Рассылка отправлена {sent} пользователям.")
    log_action(ADMIN_ID, f"Сделал рассылку: {text[:50]}")

async def admin_maintenance(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        await update.message.reply_text("⛔ Нет прав.")
        return
    global MAINTENANCE_MODE
    if len(context.args) < 1:
        await update.message.reply_text("❌ /maintenance on|off")
        return
    if context.args[0] == "on":
        MAINTENANCE_MODE = True
        await update.message.reply_text("🔧 Бот переведён в режим техобслуживания. Обычные пользователи не смогут им пользоваться.")
    elif context.args[0] == "off":
        MAINTENANCE_MODE = False
        await update.message.reply_text("✅ Бот снова в сети!")
    else:
        await update.message.reply_text("❌ /maintenance on|off")

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    data = query.data
    await query.answer()
    
    if data == "find":
        await find_free_tag(query, context, from_callback=True)
    elif data == "profile":
        await profile(update, context)
    elif data == "mytags":
        await mytags(update, context)
    elif data == "premium":
        await premium_menu(update, context)
    elif data.startswith("premium_buy"):
        parts = data.split("_")
        await premium_buy(update, context, int(parts[2]), int(parts[3]), parts[4])
    elif data == "support":
        await support_menu(update, context)
    elif data == "admin":
        if query.from_user.id != ADMIN_ID:
            await query.edit_message_text("⛔ Нет доступа.")
            return
        keyboard = [
            [InlineKeyboardButton("📊 Статистика", callback_data="admin_stats")],
            [InlineKeyboardButton("📜 Логи", callback_data="admin_logs")],
            [InlineKeyboardButton("💎 Выдать премиум", callback_data="admin_give")],
            [InlineKeyboardButton("🆘 Тикеты", callback_data="admin_tickets")],
            [InlineKeyboardButton("📢 Рассылка", callback_data="admin_broadcast")],
            [InlineKeyboardButton("🔧 Техработы", callback_data="admin_maintenance")],
            [InlineKeyboardButton("🔙 Назад", callback_data="back")]
        ]
        await query.edit_message_text("👑 **Админ-панель**", reply_markup=InlineKeyboardMarkup(keyboard))
    elif data == "admin_stats":
        await admin_stats(update, context)
    elif data == "admin_logs":
        await admin_logs(update, context)
    elif data == "admin_give":
        await query.edit_message_text("💎 **Выдача премиума**\n\n/givepremium <user_id> <1/2/3/4/5> <дни>", reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Назад", callback_data="admin")]]))
    elif data == "admin_tickets":
        await admin_tickets(update, context)
    elif data == "admin_broadcast":
        await query.edit_message_text("📢 **Рассылка**\n\n/broadcast <текст>", reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Назад", callback_data="admin")]]))
    elif data == "admin_maintenance":
        await query.edit_message_text("🔧 **Техработы**\n\n/maintenance on — включить\n/maintenance off — выключить", reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("🔙 Назад", callback_data="admin")]]))
    elif data == "back":
        await back(update, context)

