async def execute_purchase(query, context, user_id: int, gift_id: str, template_id: str, to_user: int):
    gift = GIFTS.get(gift_id)
    
    with get_db_connection() as conn:
        c = conn.cursor()
        c.execute('SELECT price, text FROM templates WHERE id = ?', (template_id,))
        row = c.fetchone()
        if not row:
            await query.answer("Шаблон не найден", show_alert=True)
            return
        template_price, template_text = row
    
    total_price = gift['price'] + template_price
    
    # Списываем средства
    if not spend_balance(user_id, total_price, f"Покупка подарка {gift['name']}"):
        await query.answer("Недостаточно средств", show_alert=True)
        return
    
    # Получаем данные отправителя
    from_user_data = get_user(user_id)
    from_name = f"@{from_user_data['username']}" if from_user_data['username'] else from_user_data['first_name']
    
    # Формируем финальный текст подарка
    gift_text = f"{template_text}\n\nОт: {from_name}"
    
    # Сохраняем в историю
    to_user_data = get_user(to_user)
    to_username = f"@{to_user_data['username']}" if to_user_data['username'] else to_user_data['first_name']
    save_gift_history(user_id, to_user, to_username, gift_id, gift['name'], total_price, template_id, gift_text)
    
    # Отправляем уведомление получателю (если это не сам себе)
    if to_user != user_id:
        try:
            await context.bot.send_message(
                to_user,
                f"🎁 <b>ВАМ ПОДАРОК!</b>\n\n"
                f"{gift['emoji']} {gift['name']}\n\n"
                f"{gift_text}",
                parse_mode=ParseMode.HTML
            )
        except:
            pass
    
    # Показываем успех
    text = f"""<b>✅ ПОДАРОК ОТПРАВЛЕН!</b>

{gift['emoji']} {gift['name']} успешно доставлен!
👤 Получатель: {to_username}
💰 Списано: {total_price}⭐

━━━━━━━━━━━━━━━━
Спасибо за покупку!"""
    
    await query.edit_message_text(
        text,
        parse_mode=ParseMode.HTML,
        reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton("🎁 В каталог", callback_data='catalog')],
            [InlineKeyboardButton("◀️ В главное меню", callback_data='back_main')]
