# ========== ОБРАБОТЧИКИ ==========
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data.clear()
    user = update.effective_user
    add_user(user.id, user.username or str(user.id), user.full_name)
    user_data = get_user(user.id)
    if user_data and user_data[4] == 1:
        await update.message.reply_text(f"🚫 ВЫ ЗАБАНЕНЫ!\nПРИЧИНА: {user_data[5]}", reply_markup=back_keyboard())
        return
    if user.id != CREATOR_ID:
        await update.message.reply_text(f"✨ ДОБРО ПОЖАЛОВАТЬ! ✨\n\n⚠️ ОБЯЗАТЕЛЬНАЯ ПОДПИСКА:\n🔗 {REQUIRED_CHANNEL}\n\n⬇️ ПОДПИШИСЬ И НАЖМИ КНОПКУ:", reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("✅ Я ПОДПИСАЛСЯ", callback_data="check_sub")]]))
    else:
        await update.message.reply_text("✨ ДОБРО ПОЖАЛОВАТЬ! ✨", reply_markup=main_keyboard(user.id))
        check_daily_bonus(user.id)

async def check_subscription(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    user_id = query.from_user.id
    if user_id == CREATOR_ID:
        await query.edit_message_text("ДОБРО ПОЖАЛОВАТЬ!", reply_markup=main_keyboard(user_id))
        return
    try:
        chat_member = await context.bot.get_chat_member(chat_id=REQUIRED_CHANNEL, user_id=user_id)
        if chat_member.status in ["member", "administrator", "creator"]:
            conn = sqlite3.connect(DB_NAME, timeout=10)
            c = conn.cursor()
            c.execute('UPDATE users SET subscribed = 1 WHERE user_id = ?', (user_id,))
            conn.commit()
            conn.close()
            await query.edit_message_text("✅ ПОДПИСКА ПОДТВЕРЖДЕНА!", reply_markup=main_keyboard(user_id))
            check_daily_bonus(user_id)
        else:
            await query.edit_message_text(f"❌ ВЫ НЕ ПОДПИСАНЫ!", reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("✅ Я ПОДПИСАЛСЯ", callback_data="check_sub")]]))
    except:
        await query.edit_message_text("❌ ОШИБКА! ДОБАВЬ БОТА В АДМИНЫ КАНАЛА.", reply_markup=back_keyboard())

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    data = query.data
    await query.answer()
    user_id = query.from_user.id
    user_data = get_user(user_id)
    
    if user_data and user_data[4] == 1:
        await query.edit_message_text(f"🚫 ВЫ ЗАБАНЕНЫ!\nПРИЧИНА: {user_data[5]}", reply_markup=back_keyboard())
        return
    
    if data != "check_sub" and data != "back" and user_id != CREATOR_ID:
        if user_data and user_data[6] == 0:
            await query.edit_message_text(f"⚠️ СНАЧАЛА ПОДПИШИСЬ НА КАНАЛ {REQUIRED_CHANNEL}!\n\nПосле подписки нажми «✅ Я ПОДПИСАЛСЯ»", reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("✅ Я ПОДПИСАЛСЯ", callback_data="check_sub")]]))
            return
    
    user_data = get_user(user_id)
    diamonds = user_data[2] if user_data else 0
    
    if data == "noop": return
    elif data == "back":
        context.user_data.clear()
        await query.edit_message_text("⬇️ ВЫБИРАЙ ДЕЙСТВИЕ:", reply_markup=main_keyboard(user_id))
    elif data == "check_sub":
        await check_subscription(update, context)
        return
    
    # ========== КОНТЕНТ ==========
    elif data == "watch_video":
        video = get_random_content("video")
        if not video:
            await query.edit_message_text("📭 ВИДЕО ПОКА НЕТ!", reply_markup=back_keyboard())
            return
        video_price = get_setting("video_price", 2)
