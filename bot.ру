async def handle_recipient_input(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not context.user_data.get('buying_gift'):
        return
    
    user_id = update.effective_user.id
    text = update.message.text.strip()
    
    # Извлекаем username
    username_match = re.match(r'@?([a-zA-Z0-9_]+)', text.replace('@', ''))
    if not username_match:
        await update.message.reply_text("❌ Неверный формат. Введите @username")
        return
    
    username = username_match.group(1)
    
    # Ищем пользователя по username (упрощённо)
    with get_db_connection() as conn:
        c = conn.cursor()
        c.execute('SELECT user_id FROM users WHERE username = ?', (username,))
        row = c.fetchone()
        to_user = row[0] if row else 0  # Если не найден, отправляем как есть
    
    data = context.user_data['buying_gift']
    gift_id = data['gift_id']
    
    context.user_data.pop('buying_gift')
    await show_template_selection(query=None, context=context, user_id=user_id, 
                                 gift_id=gift_id, to_user=to_user, to_name=f"@{username}")
    
    # Отправляем новое сообщение вместо старого
    await update.message.reply_text(
        f"✅ Получатель: @{username}\nТеперь выберите описание.",
        reply_markup=InlineKeyboardMarkup([
            [InlineKeyboardButton("✨ Выбрать описание", callback_data=f'recipient_{gift_id}_friend')]
        ])
    )

