# ========== TEXT HANDLER ==========
async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    text = update.message.text
    username = update.effective_user.username or str(user_id)
    user_data = get_user(user_id)
    
    if user_data and user_data[6] == 1:
        await update.message.reply_text(f"🚫 YOU ARE BANNED!\nREASON: {user_data[7]}", reply_markup=back_keyboard())
        return
    
    # Broadcast
    if context.user_data.get("awaiting_broadcast") and is_admin(user_id):
        users = get_all_users()
        sent = 0
        for u in users:
            try:
                await context.bot.send_message(chat_id=u[0], text=f"📢 BROADCAST\n\n{text}")
                sent += 1
            except:
                pass
        await update.message.reply_text(f"✅ SENT TO {sent} USERS.")
        context.user_data["awaiting_broadcast"] = False
        return
    
    # Add content
    if context.user_data.get("awaiting_content") and is_admin(user_id):
        if update.message.photo:
            file_id = update.message.photo[-1].file_id
            file_type = "photo"
            price = get_setting("photo_price", 1)
            add_content(file_type, file_id, price)
            await update.message.reply_text(f"✅ PHOTO ADDED!\n💰 PRICE: {price}💎", reply_markup=main_keyboard(user_id))
            context.user_data["awaiting_content"] = False
        elif update.message.video:
            file_id = update.message.video.file_id
            file_type = "video"
            price = get_setting("video_price", 2)
            add_content(file_type, file_id, price)
            await update.message.reply_text(f"✅ VIDEO ADDED!\n💰 PRICE: {price}💎", reply_markup=main_keyboard(user_id))
            context.user_data["awaiting_content"] = False
        else:
            await update.message.reply_text("❌ SEND PHOTO OR VIDEO!", reply_markup=back_keyboard())
        return
    
    # Add subscribe task
    if context.user_data.get("awaiting_add_task") and is_admin(user_id):
        try:
            parts = text.split("|")
            if len(parts) < 3:
                await update.message.reply_text("❌ FORMAT: `channel_username | link | bonus`")
                return
            channel_username = parts[0].strip()
            channel_link = parts[1].strip()
            bonus = int(parts[2].strip())
            add_subscribe_task(channel_username, channel_link, bonus)
            await update.message.reply_text(f"✅ TASK ADDED!\n📢 @{channel_username}\n💰 {bonus}💎", reply_markup=main_keyboard(user_id))
            context.user_data["awaiting_add_task"] = False
        except:
            await update.message.reply_text("❌ ERROR! FORMAT: `channel_username | link | bonus`")
        return
    
    # TikTok request
    if context.user_data.get("awaiting_tiktok"):
        if update.message.photo:
            file_id = update.message.photo[-1].file_id
            req_id = create_tiktok_request(user_id, username, file_id)
            await update.message.reply_text(f"✅ REQUEST #{req_id} SENT FOR MODERATION!\nADMIN WILL CHECK SOON.", reply_markup=main_keyboard(user_id))
            context.user_data["awaiting_tiktok"] = False
        else:
            await update.message.reply_text("❌ SEND SCREENSHOT (PHOTO)!", reply_markup=back_keyboard())
        return
    
    # Reject TikTok reason
    if context.user_data.get("awaiting_reject_reason") and is_admin(user_id):
        req_id = context.user_data["reject_tiktok_id"]
        reason = text
        reject_tiktok_request(req_id, reason)
        
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        c.execute('SELECT user_id FROM tiktok_moderation WHERE id = ?', (req_id,))
        req_user = c.fetchone()
        conn.close()
        
        if req_user:
            await context.bot.send_message(chat_id=req_user[0], text=f"❌ YOUR REQUEST #{req_id} REJECTED!\nREASON: {reason}")
        
        await update.message.reply_text(f"❌ REQUEST #{req_id} REJECTED!", reply_markup=main_keyboard(user_id))
        context.user_data["awaiting_reject_reason"] = False
        context.user_data["reject_tiktok_id"] = None
        return
    
    # Support
    if context.user_data.get("awaiting_support"):
        await context.bot.send_message(chat_id=CREATOR_ID, text=f"💬 MESSAGE FROM USER\n👤 @{username}\n📝 {text}")
        await update.message.reply_text("✅ MESSAGE SENT TO ADMIN!\nAWAIT REPLY.", reply_markup=main_keyboard(user_id))
        context.user_data["awaiting_support"] = False
