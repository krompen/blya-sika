# ========== ГЕНЕРАЦИЯ КРАСИВЫХ ТЕГОВ ==========
def generate_random_tag():
    # Гласные и согласные для красивых сочетаний
    vowels = 'aeiou'
    consonants = 'bcdfghjklmnpqrstvwxyz'
    length = random.choice([5, 6])
    tag = []
    for i in range(length):
        if i % 2 == 0:
            tag.append(random.choice(consonants))
        else:
            tag.append(random.choice(vowels))
    return ''.join(tag)

