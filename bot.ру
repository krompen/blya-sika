# ========== ОБРАБОТКА ТЕКСТА ==========
async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    text = update.message.text
    username = update.effective_user.username or str(user_id)
    user_data = get_user(user_id)
    
    if user_data and user_data[8] == 1:
        await update.message.reply_text(f"🚫 ВЫ ЗАБАНЕНЫ!\nПРИЧИНА: {user_data[9]}", reply_markup=back_keyboard())
        return
    
    # Рассылка
    if context.user_data.get("awaiting_broadcast") and is_admin(user_id):
        users = get_all_users()
        sent = 0
        for u in users:
            try:
                await context.bot.send_message(chat_id=u[0], text=f"📢 **РАССЫЛКА ОТ АДМИНА**\n\n{text}", parse_mode="Markdown")
                sent += 1
            except:
                pass
        await update.message.reply_text(f"✅ ОТПРАВЛЕНО {sent} ПОЛЬЗОВАТЕЛЯМ.")
        context.user_data["awaiting_broadcast"] = False
        return
    
    # Добавление контента (админ)
    if context.user_data.get("awaiting_content") and is_admin(user_id):
        if update.message.photo:
            file_id = update.message.photo[-1].file_id
            file_type = "photo"
            await update.message.reply_text("📸 ФОТО ПОЛУЧЕНО!\n\n💰 ВВЕДИ ЦЕНУ В АЛМАЗАХ (1-100):")
            context.user_data["temp_content"] = (file_type, file_id)
            context.user_data["awaiting_content_price"] = True
            context.user_data["awaiting_content"] = False
        elif update.message.video:
            file_id = update.message.video.file_id
            file_type = "video"
            await update.message.reply_text("🎬 ВИДЕО ПОЛУЧЕНО!\n\n💰 ВВЕДИ ЦЕНУ В АЛМАЗАХ (1-100):")
            context.user_data["temp_content"] = (file_type, file_id)
            context.user_data["awaiting_content_price"] = True
            context.user_data["awaiting_content"] = False
        else:
            await update.message.reply_text("❌ ОТПРАВЬ ФОТО ИЛИ ВИДЕО!", reply_markup=back_keyboard())
        return
    
    if context.user_data.get("awaiting_content_price") and is_admin(user_id):
        try:
            price = int(text)
            if price < 1 or price > 100:
                await update.message.reply_text("❌ ЦЕНА ДОЛЖНА БЫТЬ ОТ 1 ДО 100!")
                return
            file_type, file_id = context.user_data["temp_content"]
            await update.message.reply_text(f"💰 ЦЕНА: {price}💎\n\n🔒 ЭТО VIP КОНТЕНТ?\n(ДА/НЕТ)")
            context.user_data["temp_content"] = (file_type, file_id, price)
            context.user_data["awaiting_content_vip"] = True
            context.user_data["awaiting_content_price"] = False
        except:
            await update.message.reply_text("❌ ВВЕДИ ЧИСЛО!")
        return
    
    if context.user_data.get("awaiting_content_vip") and is_admin(user_id):
        is_vip = 1 if text.lower() in ["да", "yes", "vip", "1"] else 0
        file_type, file_id, price = context.user_data["temp_content"]
        add_content(file_type, file_id, price, is_vip)
        await update.message.reply_text(f"✅ КОНТЕНТ ДОБАВЛЕН!\n\n📸 ТИП: {file_type}\n💰 ЦЕНА: {price}💎\n🔒 VIP: {'ДА' if is_vip else 'НЕТ'}", reply_markup=main_keyboard(user_id))
        context.user_data["temp_content"] = None
        context.user_data["awaiting_content_vip"] = False
    
    # Добавление задания на подписку
    if context.user_data.get("awaiting_add_task") and is_admin(user_id):
        try:
            parts = text.split("|")
            if len(parts) < 3:
                await update.message.reply_text("❌ ФОРМАТ: `канал_username | ссылка | бонус`")
                return
            channel_username = parts[0].strip()
            channel_link = parts[1].strip()
            bonus = int(parts[2].strip())
            add_subscribe_task(channel_username, channel_link, bonus)
            await update.message.reply_text(f"✅ ЗАДАНИЕ ДОБАВЛЕНО!\n📢 @{channel_username}\n💰 {bonus}💎", reply_markup=main_keyboard(user_id))
            context.user_data["awaiting_add_task"] = False
        except:
            await update.message.reply_text("❌ ОШИБКА! ФОРМАТ: `канал_username | ссылка | бонус`")
        return
    
    # TikTok заявка
    if context.user_data.get("awaiting_tiktok"):
        if update.message.photo:
            file_id = update.message.photo[-1].file_id
            req_id = create_tiktok_request(user_id, username, file_id)
            await update.message.reply_text(f"✅ ЗАЯВКА #{req_id} ОТПРАВЛЕНА НА МОДЕРАЦИЮ!\nАДМИН ПРОВЕРИТ В БЛИЖАЙШЕЕ ВРЕМЯ.", reply_markup=main_keyboard(user_id))
            context.user_data["awaiting_tiktok"] = False
        else:
            await update.message.reply_text("❌ ОТПРАВЬ СКРИНШОТ (ФОТО)!", reply_markup=back_keyboard())
        return
    
    # Причина отказа TikTok
    if context.user_data.get("awaiting_reject_reason") and is_admin(user_id):
        req_id = context.user_data["reject_tiktok_id"]
        reason = text
        reject_tiktok_request(req_id, reason)
        
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        c.execute('SELECT user_id FROM tiktok_moderation WHERE id = ?', (req_id,))
        req_user = c.fetchone()
        conn.close()
        
        if req_user:
            await context.bot.send_message(chat_id=req_user[0], text=f"❌ ВАША ЗАЯВКА #{req_id} ОТКЛОНЕНА!\nПРИЧИНА: {reason}")
        
        await update.message.reply_text(f"❌ ЗАЯВКА #{req_id} ОТКЛОНЕНА!", reply_markup=main_keyboard(user_id))
        context.user_data["awaiting_reject_reason"] = False
        context.user_data["reject_tiktok_id"] = None
        return
    
    # Поддержка
    if context.user_data.get("awaiting_support"):
        await context.bot.send_message(chat_id=ADMIN_ID, text=f"💬 **СООБЩЕНИЕ ОТ ПОЛЬЗОВАТЕЛЯ**\n👤 @{username}\n📝 {text}")
        await update.message.reply_text("✅ СООБЩЕНИЕ ОТПРАВЛЕНО АДМИНУ!\nОЖИДАЙТЕ ОТВЕТА.", reply_markup=main_keyboard(user_id))
        context.user_data["awaiting_support"] = False
        return
    
    # Назначение админа
    if context.user_data.get("awaiting_make_admin") and is_admin(user_id):
        try:
            target_id = int(text)
            make_admin(target_id)
            await update.message.reply_text(f"✅ ПОЛЬЗОВАТЕЛЬ {target_id} СТАЛ АДМИНИСТРАТОРОМ!", reply_markup=main_keyboard(user_id))
            context.user_data["awaiting_make_admin"] = False
        except:
            await update.message.reply_text("❌ ОШИБКА! ВВЕДИ ID ПОЛЬЗОВАТЕЛЯ")
            context.user_data["awaiting_make_admin"] = False
        return
    
    # Бан
    if context.user_data.get("awaiting_ban_id") and is_admin(user_id):
        context.user_data["ban_target_id"] = int(text)
        await update.message.reply_text("📝 ВВЕДИ ПРИЧИНУ БАНА:", reply_markup=back_keyboard())
        context.user_data["awaiting_ban_reason"] = True
        context.user_data["awaiting_ban_id"] = False
        return
    
    if context.user_data.get("awaiting_ban_reason") and is_admin(user_id):
        target_id = context.user_data["ban_target_id"]
        reason = text
        ban_user(target_id, reason)
        await update.message.reply_text(f"✅ ПОЛЬЗОВАТЕЛЬ {target_id} ЗАБАНЕН!\nПРИЧИНА: {reason}", reply_markup=main_keyboard(user_id))
        await context.bot.send_message(chat_id=target_id, text=f"🚫 ВЫ ЗАБАНЕНЫ В БОТЕ!\nПРИЧИНА: {reason}")
        context.user_data["awaiting_ban_reason"] = False
        context.user_data["ban_target_id"] = None
        return
    
    # Разбан
    if context.user_data.get("awaiting_unban") and is_admin(user_id):
        try:
            target_id = int(text)
            unban_user(target_id)
            await update.message.reply_text(f"✅ ПОЛЬЗОВАТЕЛЬ {target_id} РАЗБАНЕН!", reply_markup=main_keyboard(user_id))
            await context.bot.send_message(chat_id=target_id, text="✅ ВЫ РАЗБАНЕНЫ В БОТЕ!")
            context.user_data["awaiting_unban"] = False
        except:
            await update.message.reply_text("❌ ОШИБКА! ВВЕДИ ID ПОЛЬЗОВАТЕЛЯ")
            context.user_data["awaiting_unban"] = False
        return
    
    # Команда изменения VIP цены
    if text.startswith("/set_vip_diamonds") and is_admin(user_id):
        try:
            parts = text.split()
            new_price = int(parts[1])
            update_setting("vip_price_diamonds", new_price)
            await update.message.reply_text(f"✅ ЦЕНА VIP В АЛМАЗАХ ИЗМЕНЕНА НА {new_price}💎", reply_markup=main_keyboard(user_id))
        except:
            await update.message.reply_text("❌ /set_vip_diamonds <число>")
        return
    
    if text.startswith("/set_vip_stars") and is_admin(user_id):
        try:
            parts = text.split()
            new_price = int(parts[1])
            update_setting("vip_price_stars", new_price)
            await update.message.reply_text(f"✅ ЦЕНА VIP В ЗВЁЗДАХ ИЗМЕНЕНА НА {new_price}⭐", reply_markup=main_keyboard(user_id))
        except:
            await update.message.reply_text("❌ /set_vip_stars <число>")
        return
    
    # Если ничего не подошло
    if not context.user_data:
        await update.message.reply_text("❓ ИСПОЛЬЗУЙ КНОПКИ МЕНЮ", reply_markup=main_keyboard(user_id))

# ========== ПЛАТЕЖИ ==========
async def pre_checkout_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.pre_checkout_query
    await query.answer(ok=True)

async def successful_payment_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    payload = update.message.successful_payment.invoice_payload
    
    if payload.startswith("diamonds_"):
        amount = int(payload.split("_")[1])
        add_diamonds(user_id, amount, "purchase", f"Покупка {amount} алмазов")
        await update.message.reply_text(f"✅ ОПЛАТА ПРОШЛА УСПЕШНО!\n💰 ПОЛУЧЕНО {amount}💎", reply_markup=main_keyboard(user_id))
    
    elif payload == "vip_stars":
        set_vip(user_id)
        await update.message.reply_text(f"✅ ПОЗДРАВЛЯЮ! ВЫ СТАЛИ VIP!\nСПАСИБО ЗА ПОКУПКУ!", reply_markup=main_keyboard(user_id))

# ========== ЗАПУСК ==========
def main():
    app = Application.builder().token(TOKEN).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(PreCheckoutQueryHandler(pre_checkout_handler))
    app.add_handler(MessageHandler(filters.SUCCESSFUL_PAYMENT, successful_payment_handler))
    app.add_handler(MessageHandler(filters.PHOTO | filters.VIDEO | filters.TEXT & ~filters.COMMAND, handle_text))
    app.add_handler(CallbackQueryHandler(button_handler))
    
    print("🚀 КОНТЕНТ-БОТ ЗАПУЩЕН!")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()