# ========== ОСТАВИТЬ ОТЗЫВ ==========
async def start_review(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    now = datetime.now()
    
    if user_id in last_review_time:
        last = last_review_time[user_id]
        if now - last < timedelta(minutes=ANTISPAM_MINUTES):
            wait = ANTISPAM_MINUTES - (now - last).seconds // 60
            await update.message.reply_text(f"⏳ ПОДОЖДИ {wait} МИНУТ\n\nНельзя так часто оставлять отзывы", reply_markup=get_menu(user_id))
            return ConversationHandler.END
    
    await update.message.reply_text("⭐ ПОСТАВЬ ОЦЕНКУ ⭐\n\nВыбери от 1 до 5 звёзд:", reply_markup=stars_buttons())
    return RATING

async def get_rating(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    rating = int(query.data.split("_")[1])
    context.user_data["rating"] = rating
    
    await query.edit_message_text(
        f"✨ ОЦЕНКА: {'⭐' * rating} ({rating}/5) ✨\n\n✏️ НАПИШИ ОТЗЫВ\n\nОбязательно упомяни {MY_USERNAME}\nМинимум {MIN_REVIEW_LENGTH} символов:",
        reply_markup=cancel_btn()
    )
    return REVIEW_TEXT

async def get_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text.strip()
    
    if len(text) < MIN_REVIEW_LENGTH:
        await update.message.reply_text(f"❌ СЛИШКОМ КОРОТКО\n\nНапиши минимум {MIN_REVIEW_LENGTH} символов:", reply_markup=cancel_btn())
        return REVIEW_TEXT
    
    if MY_USERNAME not in text:
        await update.message.reply_text(f"❌ УПОМЯНИ {MY_USERNAME}\n\nНапиши отзыв снова:", reply_markup=cancel_btn())
        return REVIEW_TEXT
    
    context.user_data["review_text"] = text
    rating = context.user_data["rating"]
    
    await update.message.reply_text(
        f"📝 ПРЕДПРОСМОТР 📝\n\n⭐ ОЦЕНКА: {'⭐' * rating} ({rating}/5)\n📝 ТЕКСТ: {text[:200]}\n\n✅ ВСЁ ВЕРНО?",
        reply_markup=confirm_buttons()
    )
    return CONFIRM

async def confirm_review(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    if query.data == "confirm_no":
        await query.edit_message_text("❌ ОТЗЫВ ОТМЕНЁН")
        await query.message.reply_text("ГЛАВНОЕ МЕНЮ:", reply_markup=get_menu(query.from_user.id))
        context.user_data.clear()
        return ConversationHandler.END
    
    user = query.from_user
    rating = context.user_data["rating"]
    text = context.user_data["review_text"]
    username = f"@{user.username}" if user.username else None
    
    new_review = {
        "id": len(reviews) + 1,
        "user_id": user.id,
        "username": username,
        "rating": rating,
        "text": text,
        "date": datetime.now().isoformat(),
        "deleted": False
    }
    reviews.append(new_review)
    save_reviews(reviews)
    last_review_time[user.id] = datetime.now()
    
    try:
        await context.bot.send_message(
            chat_id=CHANNEL_REVIEWS,
            text=f"⭐ НОВЫЙ ОТЗЫВ ⭐\n\nОЦЕНКА: {'⭐' * rating} ({rating}/5)\nОТ: {username or 'АНОНИМ'}\n\n📝 {text}"
        )
    except Exception as e:
        print(f"Ошибка отправки в канал: {e}")
    
    await query.edit_message_text("✅ СПАСИБО ЗА ОТЗЫВ!\n\nТвой отзыв опубликован в канале")
    await query.message.reply_text("ГЛАВНОЕ МЕНЮ:", reply_markup=get_menu(user.id))
    context.user_data.clear()
    return ConversationHandler.END

async def cancel_review(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.callback_query:
        await update.callback_query.answer()
        await update.callback_query.edit_message_text("❌ ОТМЕНЕНО")
        await update.callback_query.message.reply_text("ГЛАВНОЕ МЕНЮ:", reply_markup=get_menu(update.callback_query.from_user.id))
    else:
        await update.message.reply_text("❌ ОТМЕНЕНО", reply_markup=get_menu(update.effective_user.id))
    context.user_data.clear()
    return ConversationHandler.END

