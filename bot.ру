# --- CALLBACKS ---
@bot.callback_query_handler(func=lambda call: True)
def callbacks(call):
    uid = call.message.chat.id
    if call.data.startswith("search_"):
        bot.answer_callback_query(call.id, "Запуск поиска...")
        call.message.text = f"🔎 {call.data.split('_')[1]} БУКВ"
        route(call.message)

    elif call.data.startswith("buy_"):
        bot.send_message(uid, f"💳 Для оплаты напишите администратору {ADMIN_USERNAME}\nУкажите ваш ID: `{uid}`")

    elif call.data == "a_mail" and uid == ADMIN_ID:
        m = bot.send_message(uid, "💬 Введите текст сообщения для всех пользователей:", reply_markup=back_kb())
        bot.register_next_step_handler(m, admin_mail)

def admin_mail(message):
    if message.text == "⬅️ НАЗАД В МЕНЮ": return
    c.execute("SELECT user_id FROM users")
    all_u = c.fetchall()
    ok = 0
    for u in all_u:
        try:
            bot.send_message(u[0], message.text)
            ok += 1
            time.sleep(0.1)
        except: pass
    bot.send_message(ADMIN_ID, f"✅ Рассылка завершена. Успешно: {ok}", reply_markup=main_kb(ADMIN_ID))

