def use_promocode(user_id, code):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    code = code.upper()
    c.execute('SELECT id, diamonds, expires_at FROM promocodes WHERE code = ? AND uses > 0', (code,))
    promo = c.fetchone()
    if not promo:
        conn.close()
        return False, "Промокод не найден"
    if datetime.datetime.strptime(promo[2], "%Y-%m-%d %H:%M:%S") < datetime.datetime.now():
        conn.close()
        return False, "Промокод истек"
    c.execute('SELECT * FROM promo_used WHERE user_id = ? AND promo_id = ?', (user_id, promo[0]))
    if c.fetchone():
        conn.close()
        return False, "Вы уже использовали этот промокод"
    c.execute('INSERT INTO promo_used (user_id, promo_id, used_at) VALUES (?, ?, ?)', (user_id, promo[0], datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")))
    c.execute('UPDATE promocodes SET uses = uses - 1 WHERE id = ?', (promo[0],))
    conn.commit()
    conn.close()
    add_diamonds(user_id, promo[1], "promocode", f"Промокод {code}")
    return True, f"Начислено {promo[1]}💎"

def create_promocode(code, diamonds, expires_days=7):
    conn = sqlite3.connect(DB_NAME, timeout=10)
