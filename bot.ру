    ])
    await update.message.reply_text("🔐 АДМИН ПАНЕЛЬ 🔐\n\nВыбери действие:", reply_markup=keyboard)

async def admin_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    if query.from_user.id != ADMIN_ID:
        return
    
    if query.data == "admin_stats":
        active = [r for r in reviews if not r.get("deleted", False)]
        if not active:
            text = "📊 НЕТ ОТЗЫВОВ"
        else:
            avg = sum(r["rating"] for r in active) / len(active)
            pos = sum(1 for r in active if r["rating"] >= 4)
            text = f"📊 СТАТИСТИКА 📊\n\n⭐ РЕЙТИНГ: {avg:.2f}/5\n📊 ВСЕГО: {len(active)}\n👍 ПОЛОЖИТЕЛЬНЫХ: {pos}\n👎 ОТРИЦАТЕЛЬНЫХ: {len(active)-pos}"
        await query.edit_message_text(text)
    
    elif query.data == "admin_export":
        active = [r for r in reviews if not r.get("deleted", False)]
        with open("export.json", "w", encoding="utf-8") as f:
            json.dump(active, f, ensure_ascii=False, indent=2)
        await query.message.reply_document(document=open("export.json", "rb"), filename="otzyvy.json")
        os.remove("export.json")
        await query.edit_message_text("📤 ЭКСПОРТ ГОТОВ")
    
    elif query.data == "admin_broadcast":
        context.user_data["broadcast"] = True
        await query.edit_message_text("📢 ВВЕДИ ТЕКСТ РАССЫЛКИ:\n\n(отмена: /cancel_broadcast)")
    
    elif query.data == "admin_delete":
        active = [r for r in reviews if not r.get("deleted", False)]
        if not active:
            await query.edit_message_text("НЕТ ОТЗЫВОВ")
            return
        for r in active[-5:][::-1]:
            btn = InlineKeyboardMarkup([[InlineKeyboardButton("🗑 УДАЛИТЬ", callback_data=f"del_{r['id']}")]])
            await query.message.reply_text(f"ID: {r['id']}\n⭐ {'⭐'*r['rating']}\n👤 {r.get('username', 'Аноним')}\n📝 {r['text'][:100]}", reply_markup=btn)
        await query.delete_message()
    
    elif query.data.startswith("del_"):
        rid = int(query.data.split("_")[1])
        for r in reviews:
            if r["id"] == rid and not r.get("deleted", False):
                r["deleted"] = True
                save_reviews(reviews)
                await query.edit_message_text(f"✅ ОТЗЫВ {rid} УДАЛЁН")
                break

async def broadcast_msg(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if context.user_data.get("broadcast") and update.effective_user.id == ADMIN_ID:
        text = update.message.text
        users = set(r["user_id"] for r in reviews if not r.get("deleted", False))
        ok = 0
        for uid in users:
            try:
                await context.bot.send_message(uid, f"📢 РАССЫЛКА 📢\n\n{text}")
                ok += 1
            except:
                pass
        await update.message.reply_text(f"✅ ОТПРАВЛЕНО: {ok} пользователям")
        context.user_data.pop("broadcast", None)

async def cancel_broadcast(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if context.user_data.get("broadcast"):
        context.user_data.pop("broadcast")
        await update.message.reply_text("❌ РАССЫЛКА ОТМЕНЕНА", reply_markup=get_menu(update.effective_user.id))

# ========== ОБРАБОТЧИК КНОПОК ==========
async def handle_menu(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text
    if text == "🎨 ПРИМЕРЫ":
        await examples_cmd(update, context)
    elif text == "⭐ ОТЗЫВ":
        await start_review(update, context)
    elif text == "📊 ПРОФИЛЬ":
        await profile_cmd(update, context)
    elif text == "📢 КАНАЛ":
        await channel_cmd(update, context)
    elif text == "❓ FAQ":
        await faq_cmd(update, context)
    elif text == "🔐 АДМИН":
        await admin_panel(update, context)
    elif text == "❌ ОТМЕНА":
        await cancel_all(update, context)

# ========== ЗАПУСК ==========
async def set_commands(app):
    await app.bot.set_my_commands([
        BotCommand("start", "Главное меню"),
        BotCommand("delete_my_review", "Удалить мой отзыв"),
    ])

def main():
    app = Application.builder().token(TOKEN).post_init(set_commands).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("delete_my_review", delete_review))
    app.add_handler(CommandHandler("cancel_broadcast", cancel_broadcast))
    
    conv = ConversationHandler(
        entry_points=[MessageHandler(filters.Regex("^⭐ ОТЗЫВ$"), start_review)],
        states={
            RATING: [CallbackQueryHandler(get_rating, pattern="^rate_")],
            REVIEW_TEXT: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_text)],
            CONFIRM: [CallbackQueryHandler(confirm_review, pattern="^confirm_")],
        },
        fallbacks=[CallbackQueryHandler(cancel_review, pattern="^cancel$"), CommandHandler("cancel", cancel_all)]
    )
    app.add_handler(conv)
    
    app.add_handler(CallbackQueryHandler(admin_callback, pattern="^(admin_|del_)"))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, broadcast_msg))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_menu))
    
    print("✅ БОТ ЗАПУЩЕН!")
    app.run_polling()

if __name__ == "__main__":
    main()