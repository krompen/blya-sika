async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    text = update.message.text
    user_data = get_user(user_id)
    if user_data and user_data[5] == 1:
        await update.message.reply_text("🚫 ВЫ ЗАБАНЕНЫ!")
        return

    # РАССЫЛКА
    if context.user_data.get("awaiting_broadcast") and is_admin(user_id):
        users = get_all_users()
        sent = 0
        for u in users:
            try:
                await context.bot.send_message(chat_id=u[0], text=f"📢 РАССЫЛКА\n\n{text}")
                sent += 1
            except: pass
        await update.message.reply_text(f"✅ ОТПРАВЛЕНО {sent} ПОЛЬЗОВАТЕЛЯМ.")
        context.user_data["awaiting_broadcast"] = False
        return

    # ПРОМОКОД
    if context.user_data.get("awaiting_promocode"):
        success, msg = use_promocode(user_id, text)
        await update.message.reply_text(msg, reply_markup=main_keyboard(user_id))
        context.user_data["awaiting_promocode"] = False
        return

    # ПОДДЕРЖКА
    if context.user_data.get("awaiting_support"):
        await context.bot.send_message(CREATOR_ID, f"💬 ОТ @{update.effective_user.username}: {text}")
        await update.message.reply_text("✅ ОТПРАВЛЕНО!", reply_markup=main_keyboard(user_id))
        context.user_data["awaiting_support"] = False
        return

    # TIKTOK ЗАЯВКА
    if context.user_data.get("awaiting_tiktok"):
        if update.message.photo:
            file_id = update.message.photo[-1].file_id
            req_id = create_tiktok_request(user_id, update.effective_user.username, file_id)
            await update.message.reply_text(f"✅ ЗАЯВКА #{req_id} ОТПРАВЛЕНА НА МОДЕРАЦИЮ!", reply_markup=main_keyboard(user_id))
            await context.bot.send_message(CREATOR_ID, f"🎬 НОВАЯ ЗАЯВКА #{req_id} ОТ @{update.effective_user.username}")
            context.user_data["awaiting_tiktok"] = False
        else:
            await update.message.reply_text("❌ ОТПРАВЬ ФОТО!")
        return

    # ОТКАЗ TIKTOK (ПРИЧИНА)
    if context.user_data.get("awaiting_reject_reason") and is_admin(user_id):
        req_id = context.user_data["rej_tik"]
        reject_tiktok_request(req_id, text)
        await update.message.reply_text(f"❌ ЗАЯВКА #{req_id} ОТКЛОНЕНА!")
        await context.bot.send_message(req_id, f"❌ ТВОЯ ЗАЯВКА ОТКЛОНЕНА! ПРИЧИНА: {text}")
        context.user_data["awaiting_reject_reason"] = False
        return

    # ДОБАВЛЕНИЕ КОНТЕНТА (НЕ СБРАСЫВАЕТСЯ)
    if context.user_data.get("awaiting_content") and is_admin(user_id):
        if update.message.video:
            add_content("video", update.message.video.file_id, get_setting("video_price", 2))
            await update.message.reply_text(f"✅ ВИДЕО ДОБАВЛЕНО! КИДАЙ СЛЕДУЮЩЕЕ.")
        elif update.message.photo:
            add_content("photo", update.message.photo[-1].file_id, get_setting("photo_price", 1))
            await update.message.reply_text(f"✅ ФОТО ДОБАВЛЕНО! КИДАЙ СЛЕДУЮЩЕЕ.")
        else:
            await update.message.reply_text("❌ ЭТО НЕ ФОТО/ВИДЕО!")
        return

    # ВЫХОД ИЗ РЕЖИМА ДОБАВЛЕНИЯ
    if text.lower() == "/done" and is_admin(user_id):
        context.user_data["awaiting_content"] = False
        await update.message.reply_text("✅ РЕЖИМ ДОБАВЛЕНИЯ ВЫКЛЮЧЕН.", reply_markup=admin_keyboard())
        return

    # АДМИН: ВЫДАТЬ АДМИНА
    if context.user_data.get("awaiting_make_admin") and is_creator(user_id):
        try:
            make_admin(int(text), 2)
            await update.message.reply_text(f"✅ ПОЛЬЗОВАТЕЛЬ {text} СТАЛ АДМИНОМ!")
            await context.bot.send_message(int(text), "👑 ВЫ СТАЛИ АДМИНОМ!")
        except: await update.message.reply_text("❌ ОШИБКА!")
        context.user_data["awaiting_make_admin"] = False
        return

    # АДМИН: РАЗЖАЛОВАТЬ
    if context.user_data.get("awaiting_demote") and is_creator(user_id):
        try:
            make_admin(int(text), 0)
            await update.message.reply_text(f"✅ ПОЛЬЗОВАТЕЛЬ {text} РАЗЖАЛОВАН!")
        except: await update.message.reply_text("❌ ОШИБКА!")
        context.user_data["awaiting_demote"] = False
        return

    # АДМИН: ВЫДАТЬ АЛМАЗЫ
    if context.user_data.get("awaiting_give_diamonds") and is_admin(user_id):
        try:
            parts = text.split()
            add_diamonds(int(parts[0]), int(parts[1]), "admin", "Выдача админом")
            await update.message.reply_text(f"✅ ВЫДАНО {parts[1]}💎 ПОЛЬЗОВАТЕЛЮ {parts[0]}!")
            await context.bot.send_message(int(parts[0]), f"🎁 ВАМ ВЫДАНО {parts[1]}💎 АДМИНОМ!")
        except: await update.message.reply_text("❌ ФОРМАТ: ID СУММА")
        context.user_data["awaiting_give_diamonds"] = False
        return

    # АДМИН: ЗАБРАТЬ АЛМАЗЫ
    if context.user_data.get("awaiting_take_diamonds") and is_admin(user_id):
        try:
            parts = text.split()
            remove_diamonds(int(parts[0]), int(parts[1]), "admin", "Забор админом")
            await update.message.reply_text(f"✅ ЗАБРАНО {parts[1]}💎 У {parts[0]}!")
            await context.bot.send_message(int(parts[0]), f"⚠️ У ВАС ЗАБРАНО {parts[1]}💎 АДМИНОМ!")
        except: await update.message.reply_text("❌ НЕДОСТАТОЧНО АЛМАЗОВ ИЛИ НЕВЕРНЫЙ ФОРМАТ!")
        context.user_data["awaiting_take_diamonds"] = False
        return

    # АДМИН: БАН
    if context.user_data.get("awaiting_ban_id") and is_admin(user_id):
        context.user_data["ban_id"] = int(text)
        await update.message.reply_text("ВВЕДИ ПРИЧИНУ БАНА:")
        context.user_data["awaiting_ban_reason"] = True
        context.user_data["awaiting_ban_id"] = False
        return

    if context.user_data.get("awaiting_ban_reason") and is_admin(user_id):
        ban_user(context.user_data["ban_id"], text)
        await update.message.reply_text(f"✅ ПОЛЬЗОВАТЕЛЬ {context.user_data['ban_id']} ЗАБАНЕН! ПРИЧИНА: {text}")
        await context.bot.send_message(context.user_data["ban_id"], f"🚫 ВЫ ЗАБАНЕНЫ! ПРИЧИНА: {text}")
        context.user_data["awaiting_ban_reason"] = False
        return

    # АДМИН: РАЗБАН
    if context.user_data.get("awaiting_unban") and is_admin(user_id):
        unban_user(int(text))
        await update.message.reply_text(f"✅ ПОЛЬЗОВАТЕЛЬ {text} РАЗБАНЕН!")
        await context.bot.send_message(int(text), "✅ ВЫ РАЗБАНЕНЫ!")
        context.user_data["awaiting_unban"] = False
        return

    # НАСТРОЙКИ ЦЕН
    if context.user_data.get("awaiting_set_photo_price") and is_admin(user_id):
        update_setting("photo_price", int(text))
        await update.message.reply_text(f"✅ ЦЕНА ФОТО: {text}💎")
        context.user_data["awaiting_set_photo_price"] = False
        return
    if context.user_data.get("awaiting_set_video_price") and is_admin(user_id):
        update_setting("video_price", int(text))
        await update.message.reply_text(f"✅ ЦЕНА ВИДЕО: {text}💎")
        context.user_data["awaiting_set_video_price"] = False
        return
    if context.user_data.get("awaiting_set_daily_bonus") and is_admin(user_id):
        update_setting("daily_bonus", int(text))
        await update.message.reply_text(f"✅ БОНУС: {text}💎")
        context.user_data["awaiting_set_daily_bonus"] = False
        return
    if context.user_data.get("awaiting_set_ref_bonus") and is_admin(user_id):
        update_setting("ref_bonus", int(text))
        await update.message.reply_text(f"✅ РЕФ БОНУС: {text}💎")
        context.user_data["awaiting_set_ref_bonus"] = False
        return
    if context.user_data.get("awaiting_set_tiktok_bonus") and is_admin(user_id):
        update_setting("tiktok_bonus", int(text))
        await update.message.reply_text(f"✅ TIKTOK БОНУС: {text}💎")
        context.user_data["awaiting_set_tiktok_bonus"] = False
        return

    # КОМАНДЫ ПРОМОКОДОВ
    if text.startswith("/create_promo") and is_admin(user_id):
        parts = text.split()
        if len(parts) >= 3:
            days = int(parts[3]) if len(parts) > 3 else 7
            if create_promocode(parts[1], int(parts[2]), days):
                await update.message.reply_text(f"✅ ПРОМОКОД {parts[1].upper()} СОЗДАН НА {parts[2]}💎")
            else:
                await update.message.reply_text("❌ ПРОМОКОД УЖЕ ЕСТЬ!")
        else:
            await update.message.reply_text("❌ /create_promo КОД СУММА ДНЕЙ")
        return
    if text.startswith("/delete_promo") and is_admin(user_id):
        parts = text.split()
        if len(parts) == 2:
            delete_promocode(int(parts[1]))
            await update.message.reply_text(f"✅ ПРОМОКОД #{parts[1]} УДАЛЁН!")
        return

    if not context.user_data:
        await update.message.reply_text("ИСПОЛЬЗУЙ КНОПКИ!", reply_markup=main_keyboard(user_id))

# ========== ЗАПУСК ==========
def main():
    app = Application.builder().token(TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("done", handle_text))
    app.add_handler(CommandHandler("create_promo", handle_text))
    app.add_handler(CommandHandler("delete_promo", handle_text))
    app.add_handler(MessageHandler(filters.PHOTO | filters.VIDEO | filters.TEXT & ~filters.COMMAND, handle_text))
    app.add_handler(CallbackQueryHandler(button_handler))
    print("🚀 БОТ ЗАПУЩЕН! КОНТЕНТ ДЕРЖИТСЯ, ВСЁ РАБОТАЕТ.")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()