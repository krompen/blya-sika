def init_db():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    
    # Пользователи
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        full_name TEXT,
        registered_at TEXT,
        diamonds INTEGER DEFAULT 0,
        is_vip INTEGER DEFAULT 0,
        vip_until TEXT DEFAULT NULL,
        daily_bonus_date TEXT DEFAULT NULL,
        referrer_id INTEGER DEFAULT NULL,
        ref_earned INTEGER DEFAULT 0,
        is_banned INTEGER DEFAULT 0,
        ban_reason TEXT DEFAULT NULL,
        level INTEGER DEFAULT 0
    )''')
    
    # Контент (видео/фото)
    c.execute('''CREATE TABLE IF NOT EXISTS content (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        type TEXT,
        file_id TEXT,
        price INTEGER,
        is_vip INTEGER DEFAULT 0,
        created_at TEXT
    )''')
    
    # Задания на подписку
    c.execute('''CREATE TABLE IF NOT EXISTS subscribe_tasks (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        channel_username TEXT,
        channel_link TEXT,
        bonus INTEGER DEFAULT 5,
        created_at TEXT
    )''')
    
    # Выполненные подписки
    c.execute('''CREATE TABLE IF NOT EXISTS user_subscribes (
        user_id INTEGER,
        task_id INTEGER,
        completed_at TEXT,
        PRIMARY KEY (user_id, task_id)
    )''')
    
    # Заявки на модерацию TikTok
    c.execute('''CREATE TABLE IF NOT EXISTS tiktok_moderation (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        username TEXT,
        screenshot_file_id TEXT,
        status TEXT DEFAULT 'pending',
        created_at TEXT,
        reviewed_at TEXT,
        review_comment TEXT
    )''')
    
    # Реферальные ссылки
    c.execute('''CREATE TABLE IF NOT EXISTS referrals (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        referrer_id INTEGER,
        referred_id INTEGER,
        created_at TEXT,
        bonus_paid INTEGER DEFAULT 0
    )''')
    
    # Транзакции
    c.execute('''CREATE TABLE IF NOT EXISTS transactions (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        amount INTEGER,
        type TEXT,
        description TEXT,
        created_at TEXT
    )''')
    
    # Настройки бота
    c.execute('''CREATE TABLE IF NOT EXISTS bot_settings (
        key TEXT PRIMARY KEY,
        value TEXT
    )''')
    
    # Добавляем настройки по умолчанию
    c.execute('INSERT OR IGNORE INTO bot_settings (key, value) VALUES ("vip_price_diamonds", "500")')
