async def start_review(update: Update, context: ContextTypes.DEFAULT_TYPE):
    reset_dialog(context)
    user_id = update.effective_user.id
    now = datetime.now()
    if user_id in last_review_time:
        last = last_review_time[user_id]
        if now - last < timedelta(minutes=ANTISPAM_MINUTES):
            wait = ANTISPAM_MINUTES - (now - last).seconds // 60
            await update.message.reply_text(f"⏳ Подождите {wait} мин перед следующим отзывом.", reply_markup=main_keyboard)
            return ConversationHandler.END
    await update.message.reply_text("⭐ *Оценка работы*\n\nПоставьте оценку от 1 до 5 звёзд:", parse_mode="Markdown", reply_markup=rating_keyboard())
    return RATING

async def rating_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    rating = int(query.data.split("_")[1])
    context.user_data["rating"] = rating
    await query.edit_message_text(
        f"Вы выбрали: {'🌟' * rating} ({rating}/5)\n\nНапишите текст отзыва.\n*Обязательно упомяните {MY_USERNAME}!*\n\nМин. длина — {MIN_REVIEW_LENGTH} символов.",
        parse_mode="Markdown", reply_markup=cancel_inline
    )
    return REVIEW_TEXT

async def review_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text
    if len(text.strip()) < MIN_REVIEW_LENGTH:
        await update.message.reply_text(f"❌ Слишком коротко (мин. {MIN_REVIEW_LENGTH} символов).\nНапишите снова:", reply_markup=cancel_inline)
        return REVIEW_TEXT
    if MY_USERNAME not in text:
        await update.message.reply_text(f"⚠️ Упомяните {MY_USERNAME} в отзыве.\nНапишите снова:", reply_markup=cancel_inline)
        return REVIEW_TEXT
    context.user_data["review_text"] = text
    rating = context.user_data["rating"]
    preview = f"📝 *Предпросмотр*\n\nОценка: {'🌟' * rating} ({rating}/5)\nТекст: {text}\n\nВсё верно?"
    await update.message.reply_text(preview, parse_mode="Markdown", reply_markup=confirm_keyboard())
    return CONFIRM

async def confirm_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    if query.data == "confirm_yes":
        user = query.from_user
        rating = context.user_data["rating"]
        text = context.user_data["review_text"]
        username = f"@{user.username}" if user.username else None
        global next_review_id
        new_review = {
            "id": next_review_id, "user_id": user.id, "username": username,
            "rating": rating, "text": text, "date": datetime.now().isoformat(), "deleted": False
        }
        reviews.append(new_review)
        save_reviews(reviews)
        next_review_id += 1
        last_review_time[user.id] = datetime.now()
        save_last_time(last_review_time)
        # Отправка в канал
        await query.bot.send_message(
            chat_id=f"@{CHANNEL_REVIEWS_USERNAME}",
            text=f"⭐ *Новый отзыв о {MY_USERNAME}*\n\nОценка: {'🌟' * rating} ({rating}/5)\n"
                 f"От: {username or 'пользователь'}\n📝 {text}",
            parse_mode="Markdown"
        )
        await query.edit_message_text("✅ *Спасибо за отзыв!* Он опубликован в канале.", parse_mode="Markdown")
        await query.message.reply_text("Главное меню:", reply_markup=main_keyboard)
    else:
        await query.edit_message_text("❌ Отмена.")
        await query.message.reply_text("Главное меню:", reply_markup=main_keyboard)
    context.user_data.clear()
    return ConversationHandler.END

async def cancel_dialog(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.callback_query:
        await update.callback_query.answer()
        await update.callback_query.edit_message_text("❌ Отменено.")
        await update.callback_query.message.reply_text("Главное меню:", reply_markup=main_keyboard)
    else:
        await update.message.reply_text("❌ Отменено.", reply_markup=main_keyboard)
    context.user_data.clear()
    return ConversationHandler.END

