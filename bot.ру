def create_promocode(code, diamonds):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    try:
        c.execute('INSERT INTO promocodes (code, diamonds) VALUES (?, ?)', (code.upper(), diamonds))
        conn.commit()
        conn.close()
        return True
    except:
        conn.close()
        return False

def use_promocode(user_id, code):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT diamonds FROM promocodes WHERE code = ?', (code.upper(),))
    promo = c.fetchone()
    if promo:
        add_diamonds(user_id, promo[0])
        c.execute('DELETE FROM promocodes WHERE code = ?', (code.upper(),))
        conn.commit()
        conn.close()
        return True, promo[0]
    conn.close()
    return False, 0

