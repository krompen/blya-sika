def get_profile_text():
    active_reviews = [r for r in reviews if not r.get("deleted", False)]
    if not active_reviews:
        return ("📋 *Мой профиль*\n\n⭐ Средняя оценка: *нет отзывов*\n📊 Всего отзывов: 0\n"
                "   👍 Положительных (4-5): 0\n   👎 Отрицательных (1-3): 0\n\nПока нет ни одного отзыва. Будь первым! ⭐")
    total = len(active_reviews)
    positive = sum(1 for r in active_reviews if r["rating"] >= 4)
    negative = total - positive
    avg = sum(r["rating"] for r in active_reviews) / total
    last_three = active_reviews[-3:][::-1]
    last_text = ""
    for r in last_three:
        stars = "🌟" * r["rating"]
        username = r.get("username", "пользователь")
        if not username or username == "None":
            username = "пользователь"
        date = r["date"][:10]
        last_text += f"\n{stars} *{username}* ({date})\n_{r['text'][:80]}..._\n"
    return (f"📋 *Мой профиль*\n\n⭐ Средняя оценка: *{avg:.1f} / 5.0*\n📊 Всего отзывов: {total}\n"
            f"   👍 Положительных (4-5): {positive}\n   👎 Отрицательных (1-3): {negative}\n\n📝 *Последние отзывы:*{last_text}")

def get_stats_for_admin():
    active = [r for r in reviews if not r.get("deleted", False)]
    if not active:
        return "📊 *Статистика*\n\nНет отзывов."
    avg = sum(r["rating"] for r in active) / len(active)
    positive = sum(1 for r in active if r["rating"] >= 4)
    unique_users = len(set(r["user_id"] for r in active))
    return (f"📊 *Статистика*\n\nВсего отзывов: {len(active)}\nСредний рейтинг: {avg:.2f}\n"
            f"Положительных: {positive}\nОтрицательных: {len(active) - positive}\nУникальных авторов: {unique_users}")

