async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data.clear()
    user = update.effective_user
    add_user(user.id, user.username or str(user.id), user.full_name)
    user_data = get_user(user.id)
    if user_data and user_data[5] == 1:
        await update.message.reply_text("🚫 ВЫ ЗАБАНЕНЫ!", reply_markup=back_keyboard())
        return
    if user.id != CREATOR_ID:
        await update.message.reply_text(f"✨ ДОБРО ПОЖАЛОВАТЬ! ✨\n\n⚠️ ПОДПИШИСЬ НА КАНАЛ: {REQUIRED_CHANNEL}", reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("✅ Я ПОДПИСАЛСЯ", callback_data="check_sub")]]))
    else:
        await update.message.reply_text("✨ ДОБРО ПОЖАЛОВАТЬ! ✨", reply_markup=main_keyboard(user.id))
        check_daily_bonus(user.id)

async def check_subscription(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    user_id = query.from_user.id
    if user_id == CREATOR_ID:
        await query.edit_message_text("ДОБРО ПОЖАЛОВАТЬ!", reply_markup=main_keyboard(user_id))
        return
    try:
        chat_member = await context.bot.get_chat_member(chat_id=REQUIRED_CHANNEL, user_id=user_id)
        if chat_member.status in ["member", "administrator", "creator"]:
            conn = sqlite3.connect(DB_NAME, timeout=10)
            c = conn.cursor()
            c.execute('UPDATE users SET subscribed = 1 WHERE user_id = ?', (user_id,))
            conn.commit()
            conn.close()
            await query.edit_message_text("✅ ПОДПИСКА ПОДТВЕРЖДЕНА!", reply_markup=main_keyboard(user_id))
            check_daily_bonus(user_id)
        else:
            await query.edit_message_text(f"❌ ВЫ НЕ ПОДПИСАНЫ!", reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("✅ Я ПОДПИСАЛСЯ", callback_data="check_sub")]]))
    except:
        await query.edit_message_text("❌ ОШИБКА! ДОБАВЬ БОТА В АДМИНЫ КАНАЛА.", reply_markup=back_keyboard())

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    data = query.data
    await query.answer()
    user_id = query.from_user.id
    user_data = get_user(user_id)
    if user_data and user_data[5] == 1:
        await query.edit_message_text("🚫 ВЫ ЗАБАНЕНЫ!", reply_markup=back_keyboard())
        return

    # НОВАЯ БЫСТРАЯ ВЫДАЧА ВИДЕО
    if data == "watch_video":
        video = get_random_content("video")
        if not video:
            await query.edit_message_text("📭 ВИДЕО НЕТ!", reply_markup=back_keyboard())
            return
        price = get_setting("video_price", 2)
        if remove_diamonds(user_id, price, "watch_video", "Просмотр видео"):
            await query.edit_message_text(f"✅ -{price}💎")
            await context.bot.send_video(chat_id=user_id, video=video[1])
            await context.bot.send_message(chat_id=user_id, text="🎬 ДАЛЬШЕ?", reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("🎬 ЕЩЁ", callback_data="watch_video")], [InlineKeyboardButton("🔙 МЕНЮ", callback_data="back")]]))
            await query.message.delete()
        else:
            await query.edit_message_text(f"❌ НЕТ {price}💎!", reply_markup=back_keyboard())
        return

    # НОВАЯ БЫСТРАЯ ВЫДАЧА ФОТО
    if data == "watch_photo":
        photo = get_random_content("photo")
        if not photo:
            await query.edit_message_text("📭 ФОТО НЕТ!", reply_markup=back_keyboard())
            return
        price = get_setting("photo_price", 1)
        if remove_diamonds(user_id, price, "watch_photo", "Просмотр фото"):
            await query.edit_message_text(f"✅ -{price}💎")
            await context.bot.send_photo(chat_id=user_id, photo=photo[1])
            await context.bot.send_message(chat_id=user_id, text="📸 ДАЛЬШЕ?", reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("📸 ЕЩЁ", callback_data="watch_photo")], [InlineKeyboardButton("🔙 МЕНЮ", callback_data="back")]]))
            await query.message.delete()
        else:
            await query.edit_message_text(f"❌ НЕТ {price}💎!", reply_markup=back_keyboard())
        return

    # ОСТАЛЬНЫЕ КНОПКИ
    if data == "back":
        context.user_data.clear()
        await query.edit_message_text("ГЛАВНОЕ МЕНЮ", reply_markup=main_keyboard(user_id))
    elif data == "check_sub":
        await check_subscription(update, context)
    elif data == "promocode":
        await query.edit_message_text("ВВЕДИ ПРОМОКОД:", reply_markup=back_keyboard())
        context.user_data["awaiting_promocode"] = True
    elif data == "support":
        await query.edit_message_text("НАПИШИ СООБЩЕНИЕ:", reply_markup=back_keyboard())
        context.user_data["awaiting_support"] = True
    elif data == "daily_bonus":
        if check_daily_bonus(user_id):
            await query.edit_message_text(f"✅ +{get_setting('daily_bonus',5)}💎", reply_markup=back_keyboard())
        else:
            await query.edit_message_text("❌ УЖЕ ЗАБИРАЛ!", reply_markup=back_keyboard())
    elif data == "ref_system":
        ref_link = f"https://t.me/{context.bot.username}?start=ref_{user_id}"
