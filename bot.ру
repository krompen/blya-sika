async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    text = update.message.text
    user = get_user(user_id)
    
    if user and user[1] == 1:
        await update.message.reply_text("🚫 ВЫ ЗАБАНЕНЫ!")
        return
    
    # РАССЫЛКА
    if context.user_data.get("awaiting_broadcast") and is_admin(user_id):
        users = get_all_users()
        sent = 0
        for u in users:
            try:
                await context.bot.send_message(chat_id=u[0], text=f"📢 РАССЫЛКА\n\n{text}")
                sent += 1
            except: pass
        await update.message.reply_text(f"✅ ОТПРАВЛЕНО {sent} ПОЛЬЗОВАТЕЛЯМ.")
        context.user_data["awaiting_broadcast"] = False
        return
    
    # ПРОМОКОД
    if context.user_data.get("awaiting_promocode"):
        success, amount = use_promocode(user_id, text)
        if success:
            await update.message.reply_text(f"✅ НАЧИСЛЕНО {amount}💎!", reply_markup=main_keyboard(user_id))
        else:
            await update.message.reply_text("❌ НЕВЕРНЫЙ ПРОМОКОД!", reply_markup=main_keyboard(user_id))
        context.user_data["awaiting_promocode"] = False
        return
    
    # TIKTOK
    if context.user_data.get("awaiting_tiktok"):
        if update.message.photo:
            create_tiktok_request(user_id, update.effective_user.username, update.message.photo[-1].file_id)
            await update.message.reply_text("✅ ЗАЯВКА ОТПРАВЛЕНА!", reply_markup=main_keyboard(user_id))
            await context.bot.send_message(ADMIN_ID, f"🎬 НОВАЯ ЗАЯВКА ОТ @{update.effective_user.username}")
            context.user_data["awaiting_tiktok"] = False
        else:
            await update.message.reply_text("❌ ОТПРАВЬ ФОТО!")
        return
    
    # ДОБАВЛЕНИЕ КОНТЕНТА (НЕ СБРАСЫВАЕТСЯ)
    if context.user_data.get("awaiting_content") and is_admin(user_id):
        if update.message.video:
            if add_content("video", update.message.video.file_id):
                await update.message.reply_text("✅ ВИДЕО ДОБАВЛЕНО! КИДАЙ ЕЩЁ ИЛИ /done")
            else:
                await update.message.reply_text("⚠️ ТАКОЕ ВИДЕО УЖЕ ЕСТЬ!")
        elif update.message.photo:
            if add_content("photo", update.message.photo[-1].file_id):
                await update.message.reply_text("✅ ФОТО ДОБАВЛЕНО! КИДАЙ ЕЩЁ ИЛИ /done")
            else:
                await update.message.reply_text("⚠️ ТАКОЕ ФОТО УЖЕ ЕСТЬ!")
        else:
            await update.message.reply_text("❌ ЭТО НЕ ФОТО/ВИДЕО!")
        return
    
    # ВЫХОД ИЗ РЕЖИМА
    if text.lower() == "/done" and is_admin(user_id):
        context.user_data["awaiting_content"] = False
        await update.message.reply_text("✅ РЕЖИМ ДОБАВЛЕНИЯ ВЫКЛЮЧЕН.", reply_markup=admin_keyboard())
        return
    
    # ВЫДАЧА АЛМАЗОВ
    if context.user_data.get("awaiting_give") and is_admin(user_id):
        parts = text.split()
        if len(parts) == 2:
            add_diamonds(int(parts[0]), int(parts[1]))
            await update.message.reply_text(f"✅ ВЫДАНО {parts[1]}💎 ПОЛЬЗОВАТЕЛЮ {parts[0]}!")
        else:
            await update.message.reply_text("❌ ФОРМАТ: ID СУММА")
        context.user_data["awaiting_give"] = False
        return
    
    # МАССОВЫЙ ПОДАРОК
    if context.user_data.get("awaiting_gift_all") and is_admin(user_id):
        try:
            amount = int(text)
            users = get_all_users()
            for u in users:
                add_diamonds(u[0], amount)
            await update.message.reply_text(f"✅ ВСЕМ ВЫДАНО ПО {amount}💎!")
        except:
            await update.message.reply_text("❌ ВВЕДИ ЧИСЛО!")
        context.user_data["awaiting_gift_all"] = False
        return
    
    # НАЗНАЧЕНИЕ АДМИНА
    if context.user_data.get("awaiting_make_admin") and is_creator(user_id):
        try:
            make_admin(int(text))
            await update.message.reply_text(f"✅ ПОЛЬЗОВАТЕЛЬ {text} СТАЛ АДМИНОМ!")
        except:
            await update.message.reply_text("❌ ОШИБКА!")
        context.user_data["awaiting_make_admin"] = False
        return
    
    # БАН
    if context.user_data.get("awaiting_ban") and is_admin(user_id):
        try:
            ban_user(int(text))
            await update.message.reply_text(f"✅ ПОЛЬЗОВАТЕЛЬ {text} ЗАБАНЕН!")
        except:
            await update.message.reply_text("❌ ОШИБКА!")
        context.user_data["awaiting_ban"] = False
        return
    
    # РАЗБАН
    if context.user_data.get("awaiting_unban") and is_admin(user_id):
        try:
            unban_user(int(text))
            await update.message.reply_text(f"✅ ПОЛЬЗОВАТЕЛЬ {text} РАЗБАНЕН!")
        except:
            await update.message.reply_text("❌ ОШИБКА!")
        context.user_data["awaiting_unban"] = False
        return
    
    # СОЗДАНИЕ ПРОМОКОДА
    if text.startswith("/create_promo") and is_admin(user_id):
        parts = text.split()
        if len(parts) == 3:
            if create_promocode(parts[1], int(parts[2])):
                await update.message.reply_text(f"✅ ПРОМОКОД {parts[1].upper()} НА {parts[2]}💎 СОЗДАН!")
            else:
                await update.message.reply_text("❌ ПРОМОКОД УЖЕ ЕСТЬ!")
        else:
            await update.message.reply_text("❌ /create_promo КОД СУММА")
        return
    
    if not context.user_data:
        await update.message.reply_text("ИСПОЛЬЗУЙ КНОПКИ!", reply_markup=main_keyboard(user_id))

def main():
    app = Application.builder().token(TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("done", handle_text))
    app.add_handler(CommandHandler("create_promo", handle_text))
    app.add_handler(MessageHandler(filters.PHOTO | filters.VIDEO | filters.TEXT & ~filters.COMMAND, handle_text))
    app.add_handler(CallbackQueryHandler(button_handler))
    print("🚀 БОТ ЗАПУЩЕН! ВСЁ РАБОТАЕТ!")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()