def get_user(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT user_id, username, diamonds, level, is_banned, ban_reason, subscribed FROM users WHERE user_id = ?', (user_id,))
    user = c.fetchone()
    conn.close()
    return user

def add_user(user_id, username, full_name, referrer_id=None):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT OR IGNORE INTO users (user_id, username, full_name, registered_at) VALUES (?, ?, ?, ?)', (user_id, username, full_name, now))
    if referrer_id and referrer_id != user_id:
        add_diamonds(referrer_id, get_setting("ref_bonus", 5), "referral", "Бонус за приглашение")
    if user_id == CREATOR_ID:
        c.execute('UPDATE users SET level = 3, subscribed = 1 WHERE user_id = ?', (user_id,))
    conn.commit()
    conn.close()

def add_diamonds(user_id, amount, trans_type, description):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('UPDATE users SET diamonds = diamonds + ? WHERE user_id = ?', (amount, user_id))
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT INTO transactions (user_id, amount, type, description, created_at) VALUES (?, ?, ?, ?, ?)', (user_id, amount, trans_type, description, now))
    conn.commit()
    conn.close()

def remove_diamonds(user_id, amount, trans_type, description):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('UPDATE users SET diamonds = diamonds - ? WHERE user_id = ? AND diamonds >= ?', (amount, user_id, amount))
    if c.rowcount > 0:
        now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        c.execute('INSERT INTO transactions (user_id, amount, type, description, created_at) VALUES (?, ?, ?, ?, ?)', (user_id, -amount, trans_type, description, now))
        conn.commit()
        conn.close()
        return True
    conn.close()
    return False

