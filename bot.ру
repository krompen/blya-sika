async def admin_panel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        await update.message.reply_text("⛔ Нет доступа.")
        return
    reset_dialog(context)
    keyboard = InlineKeyboardMarkup([
        [InlineKeyboardButton("📊 Статистика", callback_data="admin_stats")],
        [InlineKeyboardButton("📢 Рассылка", callback_data="admin_broadcast")],
        [InlineKeyboardButton("🗑 Управление отзывами", callback_data="admin_manage")],
        [InlineKeyboardButton("📤 Экспорт", callback_data="admin_export")]
    ])
    await update.message.reply_text("🔐 *Админ-панель*", parse_mode="Markdown", reply_markup=keyboard)

async def admin_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    if query.data == "admin_stats":
        await query.edit_message_text(get_stats_for_admin(), parse_mode="Markdown")
    elif query.data == "admin_export":
        active = [r for r in reviews if not r.get("deleted", False)]
        with open("export.json", "w", encoding="utf-8") as f:
            json.dump(active, f, ensure_ascii=False, indent=2)
        await query.message.reply_document(document=open("export.json", "rb"), filename="reviews.json")
        os.remove("export.json")
        await query.message.reply_text("Готово.")
    elif query.data == "admin_manage":
        active = [r for r in reviews if not r.get("deleted", False)][-10:]
        if not active:
            await query.edit_message_text("Нет отзывов.")
            return
        for r in active[::-1]:
            keyboard = InlineKeyboardMarkup([[InlineKeyboardButton("🗑 Удалить", callback_data=f"del_{r['id']}")]])
            await query.message.reply_text(f"ID {r['id']}: {'🌟'*r['rating']}\n{r['text'][:100]}", reply_markup=keyboard)
        await query.delete_message()
    elif query.data.startswith("del_"):
        rid = int(query.data.split("_")[1])
        for r in reviews:
            if r["id"] == rid and not r.get("deleted", False):
                r["deleted"] = True
                save_reviews(reviews)
                await query.edit_message_text(f"✅ Отзыв {rid} удалён.")
                break
    elif query.data == "admin_broadcast":
        context.user_data["broadcast"] = True
        await query.edit_message_text("Введите текст рассылки:")

async def broadcast_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if context.user_data.get("broadcast") and update.effective_user.id == ADMIN_ID:
        users = set(r["user_id"] for r in reviews if not r.get("deleted", False))
        success = 0
        for uid in users:
            try:
                await context.bot.send_message(uid, f"📢 *Рассылка:*\n\n{update.message.text}", parse_mode="Markdown")
                success += 1
                await asyncio.sleep(0.05)
            except:
                pass
        await update.message.reply_text(f"✅ Отправлено {success} пользователям.")
        context.user_data.pop("broadcast", None)

async def cancel_broadcast(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if context.user_data.get("broadcast"):
        context.user_data.pop("broadcast")
        await update.message.reply_text("Рассылка отменена.", reply_markup=main_keyboard)

# ========== ОБРАБОТКА КНОПОК ==========
async def handle_buttons(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text = update.message.text
    if text == "🎨 Примеры работ":
        await examples(update, context)
    elif text == "⭐ Оставить отзыв":
        await start_review(update, context)
    elif text == "📋 Мой профиль":
        await profile(update, context)
    elif text == "📢 Все отзывы":
        await all_reviews(update, context)
    elif text == "❓ FAQ / Инфо":
        await faq(update, context)
    elif text == "❌ Отменить всё":
        await cancel_dialog(update, context)

# ========== ЗАПУСК ==========
def main():
    app = Application.builder().token(TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("profile", profile))
    app.add_handler(CommandHandler("delete_my_review", delete_my_review))
    app.add_handler(CommandHandler("admin", admin_panel))
    app.add_handler(CommandHandler("cancel_broadcast", cancel_broadcast))
    conv = ConversationHandler(
        entry_points=[MessageHandler(filters.Regex("^⭐ Оставить отзыв$"), start_review)],
        states={
            RATING: [CallbackQueryHandler(rating_callback, pattern="^rate_")],
            REVIEW_TEXT: [MessageHandler(filters.TEXT & ~filters.COMMAND, review_text)],
            CONFIRM: [CallbackQueryHandler(confirm_callback, pattern="^confirm_")]
        },
        fallbacks=[CallbackQueryHandler(cancel_dialog, pattern="^cancel$"), CommandHandler("cancel", cancel_dialog)],
        conversation_timeout=timedelta(minutes=TIMEOUT_MINUTES)
    )
    app.add_handler(conv)
    app.add_handler(CallbackQueryHandler(admin_callback, pattern="^(admin_|del_)"))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_buttons))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, broadcast_text))
    print("✅ Бот запущен")
    app.run_polling()

if __name__ == "__main__":
    main()