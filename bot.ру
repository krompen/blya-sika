    username = update.effective_user.username or str(user_id)
    user_data = get_user(user_id)
    
    if user_data and user_data[6] == 1:
        await update.message.reply_text(f"🚫 ВЫ ЗАБАНЕНЫ!\nПРИЧИНА: {user_data[7]}", reply_markup=back_keyboard())
        return
    
    # Рассылка
    if context.user_data.get("awaiting_broadcast") and is_admin(user_id):
        users = get_all_users()
        sent = 0
        for u in users:
            try:
                await context.bot.send_message(chat_id=u[0], text=f"📢 **РАССЫЛКА**\n\n{text}", parse_mode="Markdown")
                sent += 1
            except:
                pass
        await update.message.reply_text(f"✅ ОТПРАВЛЕНО {sent} ПОЛЬЗОВАТЕЛЯМ.")
        context.user_data["awaiting_broadcast"] = False
