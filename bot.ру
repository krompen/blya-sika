checked_cache = {}
CACHE_TIME = 3600

async def is_tag_free(tag):
    if tag in checked_cache:
        cache_time, free = checked_cache[tag]
        if time.time() - cache_time < CACHE_TIME:
            return free
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(f"https://t.me/{tag}", timeout=15) as resp:
                html = await resp.text()
                if "If you have Telegram, you can contact" in html:
                    free = False
                else:
                    free = True
                checked_cache[tag] = (time.time(), free)
                return free
    except:
        return False

