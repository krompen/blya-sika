# ==================== БАЗА ДАННЫХ ====================
def init_db():
    with sqlite3.connect(DB_NAME) as conn:
        conn.execute("PRAGMA journal_mode=WAL")
        conn.execute("PRAGMA busy_timeout=30000")
        c = conn.cursor()
        
        c.execute('''CREATE TABLE IF NOT EXISTS users (
            user_id INTEGER PRIMARY KEY,
            username TEXT,
            first_name TEXT,
            balance INTEGER DEFAULT 0,
            total_spent INTEGER DEFAULT 0,
            gifts_sent INTEGER DEFAULT 0,
            gifts_received INTEGER DEFAULT 0,
            referrer_id INTEGER,
            referral_bonus INTEGER DEFAULT 0,
            is_banned INTEGER DEFAULT 0,
            created_at TEXT DEFAULT CURRENT_TIMESTAMP
        )''')
        
        c.execute('''CREATE TABLE IF NOT EXISTS transactions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER,
            type TEXT,
            amount INTEGER,
            description TEXT,
            created_at TEXT DEFAULT CURRENT_TIMESTAMP
        )''')
        
        c.execute('''CREATE TABLE IF NOT EXISTS gifts_history (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            from_user INTEGER,
            to_user INTEGER,
            to_username TEXT,
            gift_id TEXT,
            gift_name TEXT,
            price INTEGER,
            template_id TEXT,
            custom_text TEXT,
            created_at TEXT DEFAULT CURRENT_TIMESTAMP
        )''')
        
        c.execute('''CREATE TABLE IF NOT EXISTS tickets (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER,
            username TEXT,
            question TEXT,
            status TEXT DEFAULT 'open'
        )''')
        
        c.execute('''CREATE TABLE IF NOT EXISTS settings (
            key TEXT PRIMARY KEY,
            value TEXT
        )''')
        
        c.execute('''CREATE TABLE IF NOT EXISTS templates (
            id TEXT PRIMARY KEY,
            name TEXT,
            price INTEGER,
            text TEXT,
            vip INTEGER DEFAULT 0,
            active INTEGER DEFAULT 1
        )''')
        
        c.execute('INSERT OR IGNORE INTO settings (key, value) VALUES ("header_image_id", "")')
        
        # Загружаем шаблоны
        for tid, data in TEMPLATES.items():
            c.execute('''INSERT OR IGNORE INTO templates (id, name, price, text, vip, active) 
                        VALUES (?, ?, ?, ?, ?, 1)''',
                     (tid, data['name'], data['price'], data['text'], 1 if data.get('vip') else 0))
        
        conn.commit()
    logger.info("База данных инициализирована")

init_db()

# ==================== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ====================
def get_db_connection():
    return sqlite3.connect(DB_NAME, timeout=30)

def get_setting(key: str) -> Optional[str]:
    with get_db_connection() as conn:
        c = conn.cursor()
        c.execute('SELECT value FROM settings WHERE key = ?', (key,))
        row = c.fetchone()
        return row[0] if row else None

def set_setting(key: str, value: str):
    with get_db_connection() as conn:
        conn.execute('UPDATE settings SET value = ? WHERE key = ?', (value, key))
        conn.commit()

def get_user(user_id: int, username: str = "", first_name: str = "") -> Dict:
    with get_db_connection() as conn:
        c = conn.cursor()
        c.execute('''SELECT user_id, username, first_name, balance, total_spent, gifts_sent, 
                    gifts_received, referrer_id, referral_bonus, is_banned
                    FROM users WHERE user_id = ?''', (user_id,))
        row = c.fetchone()
        
        if not row:
            c.execute('''INSERT INTO users (user_id, username, first_name) 
                        VALUES (?, ?, ?)''', (user_id, username, first_name))
            conn.commit()
            return get_user(user_id, username, first_name)
        
        return {
            'user_id': row[0], 'username': row[1], 'first_name': row[2], 'balance': row[3],
            'total_spent': row[4], 'gifts_sent': row[5], 'gifts_received': row[6],
            'referrer_id': row[7], 'referral_bonus': row[8], 'is_banned': row[9]
        }

def add_balance(user_id: int, amount: int, description: str = "Пополнение"):
    with get_db_connection() as conn:
        conn.execute('UPDATE users SET balance = balance + ? WHERE user_id = ?', (amount, user_id))
        conn.execute('''INSERT INTO transactions (user_id, type, amount, description) 
                       VALUES (?, ?, ?, ?)''', (user_id, 'deposit', amount, description))
        conn.commit()

def spend_balance(user_id: int, amount: int, description: str = "Покупка подарка") -> bool:
    user = get_user(user_id)
    if user['balance'] < amount:
        return False
    
    with get_db_connection() as conn:
        conn.execute('UPDATE users SET balance = balance - ?, total_spent = total_spent + ? WHERE user_id = ?',
                    (amount, amount, user_id))
        conn.execute('''INSERT INTO transactions (user_id, type, amount, description) 
                       VALUES (?, ?, ?, ?)''', (user_id, 'spend', amount, description))
        conn.commit()
    return True

def get_balance(user_id: int) -> int:
    return get_user(user_id)['balance']

def get_active_templates():
    with get_db_connection() as conn:
        c = conn.cursor()
        c.execute('SELECT id, name, price, text, vip FROM templates WHERE active = 1 ORDER BY price, name')
        return c.fetchall()

def save_gift_history(from_user: int, to_user: int, to_username: str, gift_id: str, 
                     gift_name: str, price: int, template_id: str, custom_text: str = None):
    with get_db_connection() as conn:
        conn.execute('''INSERT INTO gifts_history (from_user, to_user, to_username, gift_id, gift_name, price, template_id, custom_text)
                       VALUES (?, ?, ?, ?, ?, ?, ?, ?)''',
                    (from_user, to_user, to_username, gift_id, gift_name, price, template_id, custom_text))
        conn.execute('UPDATE users SET gifts_sent = gifts_sent + 1 WHERE user_id = ?', (from_user,))
        conn.execute('UPDATE users SET gifts_received = gifts_received + 1 WHERE user_id = ?', (to_user,))
        conn.commit()

