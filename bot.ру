def add_tiktok_screenshot(req_id, file_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT screenshots, count FROM tiktok_requests WHERE id = ?', (req_id,))
    row = c.fetchone()
    if row:
        screenshots = row[0]
        count = row[1]
        if screenshots:
            screenshots += f",{file_id}"
        else:
            screenshots = file_id
        count += 1
        c.execute('UPDATE tiktok_requests SET screenshots = ?, count = ? WHERE id = ?', (screenshots, count, req_id))
        conn.commit()
        conn.close()
        return count
    conn.close()
    return 0

