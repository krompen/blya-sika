async def successful_payment_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    payment = update.message.successful_payment
    payload = payment.invoice_payload
    
    if payload.startswith('deposit_'):
        parts = payload.split('_')
        amount = int(parts[1])
        user_id = int(parts[2])
        
        add_balance(user_id, amount)
        
        # Проверяем реферала
        user = get_user(user_id)
        if user['referrer_id']:
            bonus = amount // 10  # 10% от пополнения
            if bonus > 0:
                with get_db_connection() as conn:
                    conn.execute('UPDATE users SET balance = balance + ?, referral_bonus = referral_bonus + ? WHERE user_id = ?',
                                (bonus, bonus, user['referrer_id']))
                    conn.commit()
                try:
                    await context.bot.send_message(
                        user['referrer_id'],
                        f"🎉 <b>РЕФЕРАЛЬНЫЙ БОНУС!</b>\n\n"
                        f"Ваш реферал пополнил баланс на {amount}⭐\n"
                        f"Вы получили: +{bonus}⭐",
                        parse_mode=ParseMode.HTML
                    )
                except:
                    pass
        
        await update.message.reply_text(
            f"✅ <b>БАЛАНС ПОПОЛНЕН!</b>\n\n"
            f"💰 Сумма: {amount}⭐\n"
            f"💳 Текущий баланс: {get_balance(user_id)}⭐",
            parse_mode=ParseMode.HTML
        )

