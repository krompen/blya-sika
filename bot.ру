def get_stats():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    total_users = c.execute('SELECT COUNT(*) FROM users').fetchone()[0]
    total_vip = c.execute('SELECT COUNT(*) FROM users WHERE is_vip = 1').fetchone()[0]
    total_content = c.execute('SELECT COUNT(*) FROM content').fetchone()[0]
    total_photos = c.execute('SELECT COUNT(*) FROM content WHERE type = "photo"').fetchone()[0]
    total_videos = c.execute('SELECT COUNT(*) FROM content WHERE type = "video"').fetchone()[0]
    pending_tiktok = c.execute('SELECT COUNT(*) FROM tiktok_moderation WHERE status = "pending"').fetchone()[0]
    conn.close()
    return total_users, total_vip, total_content, total_photos, total_videos, pending_tiktok

