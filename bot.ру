async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data.clear()
    user = update.effective_user
    
    referrer_id = None
    if context.args and context.args[0].startswith("ref_"):
        try:
            referrer_id = int(context.args[0].split("_")[1])
        except:
            pass
    
    add_user(user.id, user.username or str(user.id), referrer_id)
    
    if user.id != ADMIN_ID:
        try:
            chat_member = await context.bot.get_chat_member(chat_id=REQUIRED_CHANNEL, user_id=user.id)
            if chat_member.status not in ["member", "administrator", "creator"]:
                await update.message.reply_text(f"⚠️ ПОДПИШИСЬ НА КАНАЛ: {REQUIRED_CHANNEL}", reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("✅ ПРОВЕРИТЬ", callback_data="check_sub")]]))
