def get_user(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT diamonds, is_banned, level, referrer_id, ref_earned FROM users WHERE user_id = ?', (user_id,))
    user = c.fetchone()
    conn.close()
    return user

def add_user(user_id, username, referrer_id=None):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('INSERT OR IGNORE INTO users (user_id, username) VALUES (?, ?)', (user_id, username))
    if referrer_id and referrer_id != user_id:
        c.execute('INSERT INTO referrals (referrer_id, referred_id) VALUES (?, ?)', (referrer_id, user_id))
        c.execute('UPDATE users SET referrer_id = ? WHERE user_id = ?', (referrer_id, user_id))
        add_diamonds(referrer_id, 5)
        c.execute('UPDATE users SET ref_earned = ref_earned + 5 WHERE user_id = ?', (referrer_id,))
    conn.commit()
    conn.close()

def add_diamonds(user_id, amount):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('UPDATE users SET diamonds = diamonds + ? WHERE user_id = ?', (amount, user_id))
    conn.commit()
    conn.close()

def remove_diamonds(user_id, amount):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('UPDATE users SET diamonds = diamonds - ? WHERE user_id = ? AND diamonds >= ?', (amount, user_id, amount))
    result = c.rowcount
    conn.commit()
    conn.close()
    return result > 0

def add_content(content_type, file_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    try:
        c.execute('INSERT INTO content (type, file_id) VALUES (?, ?)', (content_type, file_id))
        conn.commit()
        conn.close()
        return True
    except:
        conn.close()
        return False

def get_random_content(content_type):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT file_id FROM content WHERE type = ? ORDER BY RANDOM() LIMIT 1', (content_type,))
    result = c.fetchone()
    conn.close()
    return result[0] if result else None

def get_all_content():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    items = c.execute('SELECT id, type FROM content').fetchall()
