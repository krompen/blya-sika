def add_diamonds(user_id, amount, trans_type, description):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('UPDATE users SET diamonds = diamonds + ? WHERE user_id = ?', (amount, user_id))
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT INTO transactions (user_id, amount, type, description, created_at) VALUES (?, ?, ?, ?, ?)',
              (user_id, amount, trans_type, description, now))
    conn.commit()
    conn.close()

def remove_diamonds(user_id, amount, trans_type, description):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('UPDATE users SET diamonds = diamonds - ? WHERE user_id = ? AND diamonds >= ?', (amount, user_id, amount))
    if c.rowcount > 0:
        now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        c.execute('INSERT INTO transactions (user_id, amount, type, description, created_at) VALUES (?, ?, ?, ?, ?)',
                  (user_id, -amount, trans_type, description, now))
        conn.commit()
        conn.close()
        return True
    conn.close()
    return False

def get_setting(key, default):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT value FROM bot_settings WHERE key = ?', (key,))
    result = c.fetchone()
    conn.close()
    if result:
        return int(result[0])
    return default

def update_setting(key, value):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('UPDATE bot_settings SET value = ? WHERE key = ?', (str(value), key))
    conn.commit()
    conn.close()

def get_all_content(content_type=None, vip_only=False):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    if content_type and vip_only:
        c.execute('SELECT id, type, file_id, price FROM content WHERE type = ? AND is_vip = 1', (content_type,))
    elif content_type:
        c.execute('SELECT id, type, file_id, price FROM content WHERE type = ? AND is_vip = 0', (content_type,))
    elif vip_only:
        c.execute('SELECT id, type, file_id, price FROM content WHERE is_vip = 1')
    else:
        c.execute('SELECT id, type, file_id, price FROM content WHERE is_vip = 0')
    content = c.fetchall()
    conn.close()
    return content

